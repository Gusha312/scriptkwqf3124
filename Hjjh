                # Если бан/невалид — останавливаем клон
                if [ "${ustatus}" = "BANNED" ] || [ "${ustatus}" = "INVALID" ]; then
                  su -c "am force-stop ${pkg}" > /dev/null 2>&1
                  disable_clone "${pkg}"
                fi
              fi
            done
            local interval mins elapsed rem_mins procs
            interval=$(cat "${INTERVAL_FILE}")
            mins=$((interval/60))
            last_launch=$(cat "${LAST_LAUNCH_FILE}")
            elapsed=$(($(date +%s) - last_launch))
            rem_mins=$(( (interval - elapsed) / 60 ))
            procs=$(get_procs_info)
            send_msg "=== Статус ===
Клонов: $(get_packages | wc -l | tr -d ' ')
Папок: $(clone_count)
Скриптов: $(list_scripts | wc -l | tr -d ' ')
До перезапуска: ${rem_mins} мин
Интервал: ${mins} мин
---
${procs}"
            ;;

          /ps)
            send_msg "Сканирую процессы..."
            local all
            all=$(get_all_procs)
            send_msg "Процессы:
${all}"
            ;;

          /vips)
            local vip_list=""
            local i=1
            for pkg in $(get_packages); do
              local short
              short=$(echo "${pkg}" | sed 's/com.roblox.//')
              if [ -f "${VIP_DIR}/${pkg}.txt" ]; then
                vip_list="${vip_list}${i}. ${short} - своя випка
"
              else
                vip_list="${vip_list}${i}. ${short} - общая
"
              fi
              i=$((i+1))
            done
            send_msg "Список випок:
${vip_list}
/setvip clienq ССЫЛКА
/clearvip clienq
/link ССЫЛКА - общая"
            ;;

          /checkaccounts)
            # Проверить куки всех клонов
            send_msg "Собираю куки для проверки..."
            create_checker
            local check_input="${HOME_DIR}/check_input.txt"
            rm -f "${check_input}"
            for pkg in $(get_packages); do
              local token=$(get_cookie_for_pkg "${pkg}")
              [ -n "${token}" ] && echo "${token}" >> "${check_input}"
            done
            if [ ! -s "${check_input}" ]; then
              send_msg "Куки не найдены ни в одном клоне"
            else
              local count=$(wc -l < "${check_input}")
              send_msg "Проверяю ${count} аккаунтов..."
              python3 "${HOME_DIR}/check_accounts.py" "${check_input}" > "${HOME_DIR}/check_log.txt" 2>&1
              local last=$(tail -1 "${HOME_DIR}/check_log.txt")
              # Отправить файлы с результатами
              for f in valid banned invalid face_verified; do
                local fp="${HOME_DIR}/${f}.txt"
                if [ -s "${fp}" ]; then
                  curl -s -X POST "https://api.telegram.org/bot${BOT_TOKEN}/sendDocument"                     -F "chat_id=${CHAT_ID}"                     -F "document=@${fp}"                     -F "caption=${f}" > /dev/null 2>&1
                fi
              done
              send_msg "Проверка завершена: ${last}"
            fi
            ;;

          /checkfile)
            send_msg "Отправь .txt файл с куками для проверки (назови check_*.txt)"
            ;;

          /cookies)
            send_msg "Собираю куки всех клонов..."
            local cookies_out="/sdcard/cookies_export.txt"
            rm -f "${cookies_out}"
            local found=0
            local i=1
            for pkg in $(get_packages); do
              local short
              short=$(echo "${pkg}" | sed 's/com.roblox.//')
              local token
              token=$(get_cookie_for_pkg "${pkg}")
              if [ -n "${token}" ]; then
                echo "${token}" >> "${cookies_out}"
                found=$((found+1))
              else
                send_msg "Клон ${i} (${short}): куки нет, пропускаю"
              fi
              i=$((i+1))
            done
            if [ "${found}" -gt 0 ]; then
              send_file "${cookies_out}" "Куки ${found} аккаунтов"
              rm -f "${cookies_out}"
            else
              send_msg "Куки не найдены ни в одном клоне"
            fi
            ;;

          /setcookies)
            send_msg "Отправь файл cookies.txt
Формат: каждая кука на новой строке
Строка 1 -> Клон 1
Строка 2 -> Клон 2
и так далее"
            ;;

          /sync)
            send_msg "Синхронизирую скрипты из RobloxClone001..."
            local n sc
            n=$(sync_scripts)
            sc=$(list_scripts | wc -l | tr -d ' ')
            send_msg "OK: синхронизировано в ${n} клонов (${sc} скриптов)"
            ;;

          /enable)
            local epkg=$(echo "${msg_text}" | cut -d' ' -f2-)
            echo "${epkg}" | grep -q "com.roblox" || epkg="com.roblox.${epkg}"
            reset_crash_count "${epkg}"
            local short=$(echo "${epkg}" | sed 's/com.roblox.//')
            send_msg "OK: ${short} включён"
            ;;

          /disable)
            local dpkg=$(echo "${msg_text}" | cut -d' ' -f2-)
            echo "${dpkg}" | grep -q "com.roblox" || dpkg="com.roblox.${dpkg}"
            disable_clone "${dpkg}"
            su -c "am force-stop ${dpkg}" > /dev/null 2>&1
            local short=$(echo "${dpkg}" | sed 's/com.roblox.//')
            send_msg "OK: ${short} отключён"
            ;;

          /crashes)
            local crash_list="" i=1
            for pkg in $(get_packages); do
              local short=$(echo "${pkg}" | sed 's/com.roblox.//')
              if is_disabled "${pkg}"; then
                crash_list="${crash_list}${i}. ${short}: ОТКЛЮЧЁН
"
              else
                local c=$(get_crash_count "${pkg}")
                crash_list="${crash_list}${i}. ${short}: ${c:-0} вылетов
"
              fi
              i=$((i+1))
            done
            send_msg "$(printf "Статистика вылетов:
${crash_list}
/enable клон - включить
/disable клон - отключить")"
            ;;

          /scripts)
            local scripts clones
            scripts=$(list_scripts)
            clones=$(clone_count)
            if [ -z "${scripts}" ]; then
              send_msg "Автоексекутер
Клонов: ${clones}
Скриптов нет — отправь .txt или /sync"
            else
              local list=""
              local i=1
              while IFS= read -r s; do
                list="${list}${i}. ${s}.txt
"
                i=$((i+1))
              done <<< "${scripts}"
              send_msg "Автоексекутер
Клонов: ${clones}
${list}
/sync - из Clone001
/delscript название - удалить"
            fi
            ;;
        esac
      fi
    fi

    echo $((uid+1)) > "${OFFSET_FILE}"
  done
}

send_msg "Менеджер запущен! Напиши /start"
watchdog_timer=0

while true; do
  check_tg
  now=$(date +%s)
  interval=$(cat "${INTERVAL_FILE}")
  last_launch=$(cat "${LAST_LAUNCH_FILE}")

  if [ $((now - last_launch)) -ge ${interval} ]; then
    send_msg "Плановый перезапуск клонов..."
    n=$(launch_all)
    send_msg "OK: перезапущено ${n} клонов"
    echo "${now}" > "${LAST_LAUNCH_FILE}"
  fi

  if [ $((now - watchdog_timer)) -ge 40 ]; then
    watchdog
    watchdog_timer=${now}
  fi

  sleep 5
done
