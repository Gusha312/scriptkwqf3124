}

# ── Куки ──
get_cookie_for_pkg() {
  local pkg=$1
  local tmp="${HOME_DIR}/cookie_tmp_${pkg##*.}.db"
  su -c "cp /data/data/${pkg}/app_webview/Default/Cookies ${tmp} && chmod 666 ${tmp}" 2>/dev/null
  local token=$(sqlite3 "${tmp}" "SELECT value FROM cookies WHERE name='.ROBLOSECURITY';" 2>/dev/null | tr -d "\r\n")
  rm -f "${tmp}"
  echo "${token}"
}

set_cookie_for_pkg() {
  local pkg=$1
  local cookie=$(echo "$2" | tr -d "\r\n")
  local db="/data/data/${pkg}/app_webview/Default/Cookies"
  local tmp="${HOME_DIR}/cookie_set_${pkg##*.}.db"
  local sql="${HOME_DIR}/cookie_cmd.sql"
  su -c "am force-stop ${pkg}" > /dev/null 2>&1
  sleep 1
  su -c "cp ${db} ${tmp} && chmod 666 ${tmp}" 2>/dev/null
  printf "UPDATE cookies SET value='%s' WHERE name='.ROBLOSECURITY';\n" "${cookie}" > "${sql}"
  sqlite3 "${tmp}" < "${sql}" 2>/dev/null
  local count=$(sqlite3 "${tmp}" "SELECT COUNT(*) FROM cookies WHERE name='.ROBLOSECURITY';" 2>/dev/null)
  if [ "${count}" = "0" ]; then
    printf "INSERT INTO cookies (creation_utc,host_key,top_frame_site_key,name,value,encrypted_value,path,expires_utc,is_secure,is_httponly,last_access_utc,has_expires,is_persistent,priority,samesite,source_scheme,source_port,is_same_party) VALUES (13000000000000000,'.roblox.com','','.ROBLOSECURITY','%s','','/',17000000000000000,1,1,13000000000000000,1,1,1,-1,2,443,0);\n" "${cookie}" > "${sql}"
    sqlite3 "${tmp}" < "${sql}" 2>/dev/null
  fi
  su -c "cp ${tmp} ${db} && chmod 600 ${db}" 2>/dev/null
  rm -f "${tmp}" "${sql}"
}

load_cookies_from_file() {
  local filepath=$1 loaded=0 line_num=0
  local pkgs=()
  while IFS= read -r pkg; do pkgs+=("${pkg}"); done <<< "$(get_packages)"
  local total=${#pkgs[@]}
  while IFS= read -r line; do
    line=$(echo "${line}" | tr -d "\r\n" | sed "s/[[:space:]]*$//")
    [ -z "${line}" ] && continue
    [ "${line_num}" -ge "${total}" ] && break
    local pkg="${pkgs[$line_num]}"
    set_cookie_for_pkg "${pkg}" "${line}"
    local short=$(echo "${pkg}" | sed 's/com.roblox.//')
    send_msg "OK: кука $((loaded+1)) -> ${short}"
    loaded=$((loaded+1))
    line_num=$((line_num+1))
  done < "${filepath}"
  echo "${loaded}"
}

# ── Автоексекутер ──
ensure_autoexec() {
  local path="${AUTOEXEC_BASE}/${1}/Codex/Autoexec"
  mkdir -p "${path}" 2>/dev/null
  echo "${path}"
}
list_scripts() {
  local first=$(get_clone_dirs | head -1)
  [ -z "${first}" ] && return
  ls "${AUTOEXEC_BASE}/${first}/Codex/Autoexec/"*.txt 2>/dev/null | xargs -I{} basename {} .txt 2>/dev/null
}
deploy_script() {
  local filename=$1 filepath=$2 count=0
  for dir in $(get_clone_dirs); do
    local path=$(ensure_autoexec "${dir}")
    cat "${filepath}" > "${path}/${filename}" 2>/dev/null && count=$((count+1))
  done
  echo "${count}"
}
delete_script() {
  local filename=$1 count=0
  for dir in $(get_clone_dirs); do
    local path="${AUTOEXEC_BASE}/${dir}/Codex/Autoexec"
    [ -f "${path}/${filename}" ] && rm -f "${path}/${filename}" && count=$((count+1))
  done
  echo "${count}"
}
sync_scripts() {
  local src="${AUTOEXEC_BASE}/RobloxClone001/Codex/Autoexec"
  [ ! -d "${src}" ] && echo "0" && return
  local count=0
  for dir in $(get_clone_dirs); do
    [ "${dir}" = "RobloxClone001" ] && continue
    local dst=$(ensure_autoexec "${dir}")
    for f in "${src}"/*.txt; do
      [ -f "${f}" ] && cat "${f}" > "${dst}/$(basename ${f})" 2>/dev/null
    done
    count=$((count+1))
  done
  echo "${count}"
}

# ── Запуск клонов ──
kill_pkg_hard() {
  su -c "am force-stop ${1}" > /dev/null 2>&1
  sleep 1
  local pid=$(su -c "ps -A" 2>/dev/null | awk -v p="${1}" '$NF==p {print $2}' | head -1)
  [ -n "${pid}" ] && su -c "kill -9 ${pid}" > /dev/null 2>&1
  sleep 1
}

launch_pkg() {
  local pkg=$1
  local vip=$(get_vip_for_pkg "${pkg}")
  su -c "am force-stop ${pkg}" > /dev/null 2>&1
  sleep 2
  su -c "monkey -p ${pkg} 1" > /dev/null 2>&1
  sleep 2
  echo "am start -a android.intent.action.VIEW -p ${pkg} -d \"${vip}\"" > "${HOME_DIR}/launch_cmd.sh"
  su -c "sh ${HOME_DIR}/launch_cmd.sh" > /dev/null 2>&1
}

launch_all() {
  local count=0
  for pkg in $(get_packages); do
    is_disabled "${pkg}" && continue
    local ustatus=$(get_cached_status "${pkg}")
    [ "${ustatus}" = "BANNED" ] || [ "${ustatus}" = "INVALID" ] && continue
    launch_pkg "${pkg}"
    set_cooldown "${pkg}"
    count=$((count+1))
    sleep 25
  done
  echo "${count}"
}

unfold_pkg() { su -c "monkey -p ${1} 1" > /dev/null 2>&1; }

# ── Watchdog ──
watchdog() {
  local ps_out=$(su -c "ps -A" 2>/dev/null)
  local problem_pkgs=""
  for pkg in $(get_packages); do
    is_disabled "${pkg}" && continue
    local ustatus=$(get_cached_status "${pkg}")
    [ "${ustatus}" = "BANNED" ] || [ "${ustatus}" = "INVALID" ] && continue
    in_cooldown "${pkg}" && continue
    local short=$(echo "${pkg}" | sed 's/com.roblox.//')
    local rss=$(echo "${ps_out}" | awk -v p="${pkg}" '$NF==p {print $5}' | head -1)
    local ram_mb=0
    [ -n "${rss}" ] && ram_mb=$(( ${rss} / 1024 ))
    local need_restart=0
    [ -z "${rss}" ] && need_restart=1
    [ "${ram_mb}" -gt 0 ] && [ "${ram_mb}" -lt 1024 ] && need_restart=1
    if [ "${need_restart}" -eq 1 ]; then
      local crashes=$(inc_crash_count "${pkg}")
      if [ "${crashes}" -ge "${MAX_CRASHES}" ]; then
        kill_pkg_hard "${pkg}"
        send_msg "ПРОБЛЕМА: ${short} вылетел ${crashes} раз -- запущу после остальных"
        problem_pkgs="${problem_pkgs} ${pkg}"
      else
        [ -z "${rss}" ] && send_msg "РЕСТАРТ: ${short} не найден (${crashes}/${MAX_CRASHES})" || send_msg "РЕСТАРТ: ${short} завис RAM:${ram_mb}MB (${crashes}/${MAX_CRASHES})"
        kill_pkg_hard "${pkg}"
        sleep 25
        launch_pkg "${pkg}"
        set_cooldown "${pkg}"
      fi
    else
      reset_crash_count "${pkg}"
      unfold_pkg "${pkg}"
    fi
  done
  for pkg in ${problem_pkgs}; do
    local short=$(echo "${pkg}" | sed 's/com.roblox.//')
    send_msg "ПЕРЕЗАПУСК: ${short}..."
    sleep 25
    launch_pkg "${pkg}"
    set_cooldown "${pkg}"
    reset_crash_count "${pkg}"
  done
}

# ── Telegram ──
send_msg() {
  local text="$1"
  curl -s -X POST "https://api.telegram.org/bot${BOT_TOKEN}/sendMessage" \
    -H "Content-Type: application/json" \
    --data-binary "{\"chat_id\":\"${CHAT_ID}\",\"parse_mode\":\"HTML\",\"text\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$text" 2>/dev/null)}" \
    > /dev/null 2>&1
}

download_file() {
  local file_id=$1 dest=$2
  local file_path=$(curl -s "https://api.telegram.org/bot${BOT_TOKEN}/getFile?file_id=${file_id}" \
    | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('result',{}).get('file_path',''))" 2>/dev/null)
  [ -z "${file_path}" ] && return 1
  curl -s -L "https://api.telegram.org/file/bot${BOT_TOKEN}/${file_path}" -o "${dest}" 2>/dev/null
  return 0
}

get_updates() {
  local offset=$(cat "${OFFSET_FILE}")
  curl -s "https://api.telegram.org/bot${BOT_TOKEN}/getUpdates?offset=${offset}&timeout=5&limit=10"
}

# ── Создать checker ──
create_checker() {
  cat > "${HOME_DIR}/check_accounts.py" << 'PYEOF'
import sys, json, urllib.request, urllib.error, time, os

def check_account(cookie):
    cookie = cookie.strip()
    if not cookie:
        return None
    headers = {"Cookie": f".ROBLOSECURITY={cookie}", "User-Agent": "Mozilla/5.0"}
    try:
        r = urllib.request.urlopen(urllib.request.Request("https://users.roblox.com/v1/users/authenticated", headers=headers), timeout=8)
        data = json.loads(r.read())
        username = data.get("name", "?")
        # Проверка бана
        banned = False
        try:
            urllib.request.urlopen(urllib.request.Request("https://accountinformation.roblox.com/v1/description", headers=headers), timeout=8)
        except urllib.error.HTTPError as e:
            if e.code == 403:
                banned = True
        # Face verify
        face = False
        try:
            r3 = urllib.request.urlopen(urllib.request.Request("https://accountinformation.roblox.com/v1/users/authenticated/age-bracket", headers=headers), timeout=8)
            face = json.loads(r3.read()).get("ageBracket", -1) == 0
        except: pass
        return {"status": "BANNED" if banned else "VALID", "username": username, "face": face, "cookie": cookie}
    except urllib.error.HTTPError as e:
        body = e.read().decode()
        if "moderated" in body.lower() or e.code == 403:
            return {"status": "BANNED", "username": "?", "face": False, "cookie": cookie}
        if e.code == 401:
            return {"status": "INVALID", "username": "?", "face": False, "cookie": cookie}
        return {"status": "ERROR", "username": "?", "face": False, "cookie": cookie}
    except Exception as e:
        return {"status": "ERROR", "username": "?", "face": False, "cookie": cookie}

input_file = sys.argv[1]
out_dir = os.path.dirname(input_file)
with open(input_file) as f:
    cookies = [l.strip() for l in f if l.strip()]

valid, banned, invalid, face_list = [], [], [], []
for i, cookie in enumerate(cookies):
    r = check_account(cookie)
    if not r: continue
    s = r["status"]; u = r["username"]; fv = r["face"]
    print(f"[{i+1}/{len(cookies)}] {s} | {u} | face:{fv}"); sys.stdout.flush()
    if s == "VALID":
        valid.append(f"{u}:{cookie}")
        if fv: face_list.append(f"{u}:{cookie}")
    elif s == "BANNED":
        banned.append(f"{u}:{cookie}")
    else:
        invalid.append(cookie[:30])
    time.sleep(0.5)

for name, lst in [("valid", valid), ("banned", banned), ("invalid", invalid), ("face_verified", face_list)]:
    with open(f"{out_dir}/{name}.txt", "w") as f:
        f.write("\n".join(lst))

print(f"DONE valid:{len(valid)} banned:{len(banned)} invalid:{len(invalid)} face:{len(face_list)}")
PYEOF
}

# ── Обработка сообщений ──
check_tg() {
  local raw=$(get_updates)
  local uids=$(echo "${raw}" | python3 -c "
import sys,json
try:
  for u in json.load(sys.stdin).get('result',[]): print(u['update_id'])
except: pass
" 2>/dev/null)

  for uid in ${uids}; do
    eval $(echo "${raw}" | python3 -c "
import sys,json,shlex
try:
  for u in json.load(sys.stdin).get('result',[]):
    if u['update_id']==$uid:
      msg=u.get('message',{})
      doc=msg.get('document',{}) or {}
      print('msg_text='+shlex.quote(msg.get('text','') or ''))
      print('file_id='+shlex.quote(doc.get('file_id','') or ''))
      print('file_name='+shlex.quote(doc.get('file_name','') or ''))
      break
except:
  print('msg_text='); print('file_id='); print('file_name=')
" 2>/dev/null)

    # Файл
    if [ -n "${file_id}" ] && echo "${file_name}" | grep -q "\.txt$"; then
      local tmp="${HOME_DIR}/tmp_${file_name}"
      send_msg "Скачиваю ${file_name}..."
      if download_file "${file_id}" "${tmp}"; then
        local size=$(wc -c < "${tmp}" 2>/dev/null || echo 0)
        if [ "${size}" -gt 0 ]; then
          if echo "${file_name}" | grep -qiE "^ban\.txt$"; then
            # Заменить куки забаненных/невалидных клонов
            local new_cookies=()
            while IFS= read -r line || [ -n "${line}" ]; do
              line=$(echo "${line}" | tr -d "
" | sed "s/[[:space:]]*$//")
              [ -n "${line}" ] && new_cookies+=("${line}")
            done < "${tmp}"
            rm -f "${tmp}"
            local replaced=0 cookie_idx=0
            for pkg in $(get_packages); do
              local ustatus=$(get_cached_status "${pkg}")
              if [ "${ustatus}" = "BANNED" ] || [ "${ustatus}" = "INVALID" ]; then
                [ "${cookie_idx}" -ge "${#new_cookies[@]}" ] && break
                local short=$(echo "${pkg}" | sed 's/com.roblox.//')
                enable_clone "${pkg}"
                set_cookie_for_pkg "${pkg}" "${new_cookies[$cookie_idx]}"
                send_msg "OK: кука для ${short} заменена"
                replaced=$((replaced+1))
                cookie_idx=$((cookie_idx+1))
              fi
            done
            send_msg "Заменено кук: ${replaced}"
          elif echo "${file_name}" | grep -qiE "^check_"; then
            cp "${tmp}" "${HOME_DIR}/check_input.txt"; rm -f "${tmp}"
            create_checker
            local count=$(wc -l < "${HOME_DIR}/check_input.txt")
            send_msg "Проверяю ${count} аккаунтов..."
            python3 "${HOME_DIR}/check_accounts.py" "${HOME_DIR}/check_input.txt" > "${HOME_DIR}/check_log.txt" 2>&1
            local last=$(tail -1 "${HOME_DIR}/check_log.txt")
            for f in valid banned invalid face_verified; do
              local fp="${HOME_DIR}/${f}.txt"
              [ -s "${fp}" ] && curl -s -X POST "https://api.telegram.org/bot${BOT_TOKEN}/sendDocument" -F "chat_id=${CHAT_ID}" -F "document=@${fp}" -F "caption=${f}" > /dev/null 2>&1
            done
            send_msg "Готово: ${last}"
          elif echo "${file_name}" | grep -qiE "cook|account|token"; then
            cp "${tmp}" "${HOME_DIR}/accounts.txt"
            local n=$(load_cookies_from_file "${tmp}"); rm -f "${tmp}"
            send_msg "OK: загружено ${n} кук в клоны"
          else
            local n=$(deploy_script "${file_name}" "${tmp}"); rm -f "${tmp}"
            send_msg "OK: ${file_name} добавлен в ${n} клонов"
          fi
        else
          rm -f "${tmp}"; send_msg "Ошибка: файл пустой"
        fi
      else
        send_msg "Ошибка: не удалось скачать"
      fi

    elif [ -n "${msg_text}" ]; then

      if echo "${msg_text}" | grep -qE "^/link .+"; then
        local lnk=$(echo "${msg_text}" | cut -d' ' -f2-)
        if echo "${lnk}" | grep -q "roblox.com"; then
          echo "${lnk}" > "${VIP_FILE}"; send_msg "OK: общая випка обновлена"
        else send_msg "Ошибка: не ссылка Roblox"; fi

      elif echo "${msg_text}" | grep -qE "^/setvip .+"; then
        local tpkg=$(echo "${msg_text}" | awk '{print $2}')
        local tlnk=$(echo "${msg_text}" | cut -d' ' -f3-)
        echo "${tpkg}" | grep -q "com.roblox" || tpkg="com.roblox.${tpkg}"
        if echo "${tlnk}" | grep -q "roblox.com"; then
          set_vip_for_pkg "${tpkg}" "${tlnk}"
          send_msg "OK: випка для $(echo ${tpkg} | sed 's/com.roblox.//') обновлена"
        else send_msg "Ошибка: не ссылка Roblox"; fi

      elif echo "${msg_text}" | grep -qE "^/clearvip .+"; then
        local cpkg=$(echo "${msg_text}" | cut -d' ' -f2-)
        echo "${cpkg}" | grep -q "com.roblox" || cpkg="com.roblox.${cpkg}"
        rm -f "${VIP_DIR}/${cpkg}.txt"
        send_msg "OK: $(echo ${cpkg} | sed 's/com.roblox.//') использует общую випку"

      elif [ "${msg_text}" = "/vips" ]; then
        local vip_list="" i=1
        for pkg in $(get_packages); do
          local short=$(echo "${pkg}" | sed 's/com.roblox.//')
          local uname=$(get_cached_name "${pkg}")
          [ -f "${VIP_DIR}/${pkg}.txt" ] && vip_list="${vip_list}${i}. ${uname}(${short}) -- своя
" || vip_list="${vip_list}${i}. ${uname}(${short}) -- общая
"
          i=$((i+1))
        done
        send_msg "Випки:
${vip_list}
/setvip клон ССЫЛКА
/clearvip клон"

      elif echo "${msg_text}" | grep -qE "^/setcookie .+"; then
        local sc_parts=$(echo "${msg_text}" | cut -d' ' -f2-)
        local sc_pkg=$(echo "${sc_parts}" | awk '{print $1}')
        local sc_cookie=$(echo "${sc_parts}" | cut -d' ' -f2-)
        echo "${sc_pkg}" | grep -q "com.roblox" || sc_pkg="com.roblox.${sc_pkg}"
        if [ -n "${sc_cookie}" ]; then
          send_msg "Устанавливаю куку для $(echo ${sc_pkg} | sed 's/com.roblox.//')..."
          set_cookie_for_pkg "${sc_pkg}" "${sc_cookie}"
          send_msg "OK: кука установлена"
        else send_msg "Ошибка: кука не указана"; fi

      elif [ "${msg_text}" = "/sync" ]; then
        send_msg "Синхронизирую скрипты из Clone001..."
        local n=$(sync_scripts)
        send_msg "OK: синхронизировано в ${n} клонов"

      elif echo "${msg_text}" | grep -qE "^/interval [0-9]+$"; then
        local mins=$(echo "${msg_text}" | awk '{print $2}')
        echo $((mins*60)) > "${INTERVAL_FILE}"
        send_msg "OK: интервал ${mins} мин"

      elif echo "${msg_text}" | grep -qE "^/delscript .+"; then
        local fname=$(echo "${msg_text}" | cut -d' ' -f2-)
        echo "${fname}" | grep -q "\.txt$" || fname="${fname}.txt"
        local n=$(delete_script "${fname}")
        send_msg "OK: ${fname} удалён из ${n} клонов"

      elif echo "${msg_text}" | grep -qE "^/enable .+"; then
        local epkg=$(echo "${msg_text}" | cut -d' ' -f2-)
        echo "${epkg}" | grep -q "com.roblox" || epkg="com.roblox.${epkg}"
        enable_clone "${epkg}"
        send_msg "OK: $(echo ${epkg} | sed 's/com.roblox.//') включён"

      elif [ "${msg_text}" = "/checkaccounts" ]; then
        send_msg "Проверяю аккаунты клонов..."
        local summary=$(check_all_accounts)
        send_msg "Готово: ${summary}"

      else
        case "${msg_text}" in
          /start|/menu)
            local mins=$(( $(cat "${INTERVAL_FILE}") / 60 ))
            send_msg "=== Dragon Adventures Manager ===
Клонов: $(get_packages | wc -l | tr -d ' ')
Папок: $(clone_count)
Перезапуск каждые: ${mins} мин

-- Управление --
/restart -- перезапустить все
/status -- статус и процессы
/ps -- процессы системы
/interval 30 -- интервал мин
/checkaccounts -- проверить акки

-- Випки --
/link ССЫЛКА -- общая
/setvip клон ССЫЛКА -- своя
/clearvip клон -- вернуть общую
/vips -- список

-- Куки --
/cookies -- получить все куки
/banned -- куки забаненных/невалидных
/setcookie клон КУКА -- установить куку
Отправь cookies.txt -- загрузить куки

-- Скрипты --
Отправь .txt -- во все клоны
/sync -- из Clone001 во все
/scripts -- список
/delscript название -- удалить
Отправь check_*.txt -- проверить аккаунты"
            ;;

          /restart)
            send_msg "Перезапускаю клоны..."
            local n=$(launch_all)
            send_msg "OK: перезапущено ${n} клонов"
            ;;

          /status)
            send_msg "Обновляю данные аккаунтов..."
            local summary=$(check_all_accounts)
            local interval=$(cat "${INTERVAL_FILE}")
            local mins=$((interval/60))
            local last_launch=$(cat "${LAST_LAUNCH_FILE}")
            local elapsed=$(($(date +%s) - last_launch))
            local rem_mins=$(( (interval - elapsed) / 60 ))
            local procs=$(get_procs_info)
            send_msg "=== Статус ===
Клонов: $(get_packages | wc -l | tr -d ' ')
Папок: $(clone_count)
Скриптов: $(list_scripts | wc -l | tr -d ' ')
До перезапуска: ${rem_mins} мин
Интервал: ${mins} мин
${summary}
---
${procs}"
            ;;

          /ps)
            send_msg "Сканирую..."
            send_msg "Процессы:
$(get_all_procs)"
            ;;

          /banned)
            local banned_out="${HOME_DIR}/banned_export.txt"
            rm -f "${banned_out}"
            local found=0
            for pkg in $(get_packages); do
              local ustatus=$(get_cached_status "${pkg}")
              if [ "${ustatus}" = "BANNED" ] || [ "${ustatus}" = "INVALID" ]; then
                local token=$(get_cookie_for_pkg "${pkg}")
                [ -n "${token}" ] && printf "%s
" "${token}" >> "${banned_out}" && found=$((found+1))
              fi
            done
            if [ "${found}" -gt 0 ]; then
              curl -s -X POST "https://api.telegram.org/bot${BOT_TOKEN}/sendDocument"                 -F "chat_id=${CHAT_ID}"                 -F "document=@${banned_out}"                 -F "caption=Бан/Невалид: ${found} аккаунтов" > /dev/null 2>&1
              rm -f "${banned_out}"
            else
              send_msg "Забаненных/невалидных аккаунтов нет"
            fi
            ;;

          /cookies)
            send_msg "Собираю куки..."
            local cookies_out="${HOME_DIR}/cookies_export.txt"
            rm -f "${cookies_out}"
            local found=0 i=1
            for pkg in $(get_packages); do
              local short=$(echo "${pkg}" | sed 's/com.roblox.//')
              local token=$(get_cookie_for_pkg "${pkg}")
              if [ -n "${token}" ]; then
                printf "%s\n" "${token}" >> "${cookies_out}"
                found=$((found+1))
              else
                send_msg "Клон ${i} (${short}): куки нет"
              fi
              i=$((i+1))
            done
            [ "${found}" -gt 0 ] && curl -s -X POST "https://api.telegram.org/bot${BOT_TOKEN}/sendDocument" -F "chat_id=${CHAT_ID}" -F "document=@${cookies_out}" -F "caption=Куки ${found} аккаунтов" > /dev/null 2>&1 && rm -f "${cookies_out}" || send_msg "Куки не найдены"
            ;;

          /scripts)
            local scripts=$(list_scripts)
            local clones=$(clone_count)
            if [ -z "${scripts}" ]; then
              send_msg "Автоексекутер
Клонов: ${clones}
Скриптов нет -- отправь .txt или /sync"
            else
              local list="" i=1
              while IFS= read -r s; do
                list="${list}${i}. ${s}.txt
"; i=$((i+1))
              done <<< "${scripts}"
              send_msg "Автоексекутер
Клонов: ${clones}
${list}
/sync -- из Clone001
/delscript название -- удалить"
            fi
            ;;

          /crashes)
            local crash_list="" i=1
            for pkg in $(get_packages); do
              local short=$(echo "${pkg}" | sed 's/com.roblox.//')
              local uname=$(get_cached_name "${pkg}")
              if is_disabled "${pkg}"; then
                crash_list="${crash_list}${i}. ${uname}(${short}): ОТКЛЮЧЁН
"
              else
                local c=$(get_crash_count "${pkg}")
                crash_list="${crash_list}${i}. ${uname}(${short}): ${c:-0} вылетов
"
              fi
              i=$((i+1))
            done
            send_msg "Вылеты:
${crash_list}
/enable клон -- включить"
            ;;
        esac
      fi
    fi

    echo $((uid+1)) > "${OFFSET_FILE}"
  done
}

# ── Старт ──
send_msg "Менеджер запущен! Проверяю аккаунты..."
summary=$(check_all_accounts)
send_msg "Проверка завершена: ${summary}
Напиши /start"

ACCOUNTS_CHECKED=1
watchdog_timer=$(( $(date +%s) + 60 ))

while true; do
  check_tg
  now=$(date +%s)
  interval=$(cat "${INTERVAL_FILE}")
  last_launch=$(cat "${LAST_LAUNCH_FILE}")

  if [ $((now - last_launch)) -ge ${interval} ]; then
    send_msg "Плановый перезапуск..."
    n=$(launch_all)
    send_msg "OK: перезапущено ${n} клонов"
    echo "${now}" > "${LAST_LAUNCH_FILE}"
  fi

  if [ "${ACCOUNTS_CHECKED}" = "1" ] && [ $((now - watchdog_timer)) -ge 40 ]; then
    watchdog
    watchdog_timer=${now}
  fi

  sleep 5
done
