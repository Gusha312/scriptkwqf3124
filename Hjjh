get_packages() {
  pm list packages | grep "com.roblox.clien" | sed 's/package://' | grep -v "^com\.roblox\.client$" | sort
}

get_clone_dirs() {
  ls "${AUTOEXEC_BASE}" 2>/dev/null | grep -E "^RobloxClone[0-9]+" | sort
}

clone_count() {
  get_clone_dirs | wc -l | tr -d ' '
}

get_vip_for_pkg() {
  local f="${VIP_DIR}/${1}.txt"
  [ -f "${f}" ] && cat "${f}" || cat "${VIP_FILE}"
}

set_vip_for_pkg() {
  echo "$2" > "${VIP_DIR}/${1}.txt"
}

set_cooldown() {
  grep -v "^${1} " "${COOLDOWN_FILE}" > "${COOLDOWN_FILE}.tmp" 2>/dev/null
  mv "${COOLDOWN_FILE}.tmp" "${COOLDOWN_FILE}" 2>/dev/null
  echo "${1} $(date +%s)" >> "${COOLDOWN_FILE}"
}

in_cooldown() {
  local t
  t=$(grep "^${1} " "${COOLDOWN_FILE}" 2>/dev/null | awk '{print $2}' | head -1)
  [ -z "${t}" ] && return 1
  [ $(( $(date +%s) - t )) -lt ${COOLDOWN_SECS} ] && return 0 || return 1
}

get_procs_info() {
  local result=""
  local i=1
  local ps_out
  ps_out=$(su -c "ps -A" 2>/dev/null)
  for pkg in $(get_packages); do
    local short
    short=$(echo "${pkg}" | sed 's/com.roblox.//')
    local line
    line=$(echo "${ps_out}" | awk -v p="${pkg}" '$NF==p {print}' | head -1)
    local vip_mark=""
    [ -f "${VIP_DIR}/${pkg}.txt" ] && vip_mark="*"
    if [ -n "${line}" ]; then
      local pid rss ram_mb
      pid=$(echo "${line}" | awk '{print $2}')
      rss=$(echo "${line}" | awk '{print $5}')
      ram_mb=$(( ${rss:-0} / 1024 ))
      if [ "${ram_mb}" -gt 1024 ]; then
        result="${result}ВКЛ Клон${i} ${short}${vip_mark} PID:${pid} RAM:${ram_mb}MB
"
      else
        result="${result}МАЛ Клон${i} ${short}${vip_mark} PID:${pid} RAM:${ram_mb}MB
"
      fi
    else
      result="${result}ВЫКЛ Клон${i} ${short}${vip_mark} офлайн
"
    fi
    i=$((i+1))
  done
  echo "${result}"
}


# Создать python скрипт проверки аккаунтов
create_checker() {
  cat > "${HOME_DIR}/check_accounts.py" << 'PYEOF'
import sys
import json
import urllib.request
import urllib.error

def check_account(cookie):
    cookie = cookie.strip()
    if not cookie:
        return None

    headers = {
        "Cookie": f".ROBLOSECURITY={cookie}",
        "User-Agent": "Mozilla/5.0"
    }

    try:
        req = urllib.request.Request(
            "https://users.roblox.com/v1/users/authenticated",
            headers=headers
        )
        r = urllib.request.urlopen(req, timeout=10)
        data = json.loads(r.read())
        username = data.get("name", "Unknown")
        user_id = data.get("id")

        # Проверка бана
        req2 = urllib.request.Request(
            "https://accountinformation.roblox.com/v1/description",
            headers=headers
        )
        banned = False
        try:
            urllib.request.urlopen(req2, timeout=10)
        except urllib.error.HTTPError as e:
            if e.code == 403:
                banned = True

        # Face verify
        req3 = urllib.request.Request(
            "https://accountinformation.roblox.com/v1/users/authenticated/age-bracket",
            headers=headers
        )
        face_verified = False
        try:
            r3 = urllib.request.urlopen(req3, timeout=10)
            d3 = json.loads(r3.read())
            face_verified = d3.get("ageBracket", -1) == 0
        except:
            pass

        return {
            "status": "BANNED" if banned else "VALID",
            "username": username,
            "user_id": user_id,
            "face_verified": face_verified,
            "cookie": cookie[:30] + "..."
        }

    except urllib.error.HTTPError as e:
        if e.code == 401:
            return {"status": "INVALID", "cookie": cookie[:30] + "..."}
        return {"status": "ERROR", "code": e.code, "cookie": cookie[:30] + "..."}
    except Exception as e:
        return {"status": "ERROR", "error": str(e), "cookie": cookie[:30] + "..."}

if __name__ == "__main__":
    input_file = sys.argv[1] if len(sys.argv) > 1 else None
    if not input_file:
        print("Usage: check_accounts.py <cookies_file>")
        sys.exit(1)

    valid = []
    banned = []
    invalid = []
    face = []

    with open(input_file, "r") as f:
        cookies = [line.strip() for line in f if line.strip()]

    total = len(cookies)
    for i, cookie in enumerate(cookies):
        result = check_account(cookie)
        if not result:
            continue
        status = result.get("status")
        username = result.get("username", "?")
        fv = result.get("face_verified", False)
        print(f"[{i+1}/{total}] {status} | {username} | face:{fv}")
        sys.stdout.flush()
        if status == "VALID":
            valid.append(f"{username}:{cookie}")
            if fv:
                face.append(f"{username}:{cookie}")
        elif status == "BANNED":
            banned.append(f"{username}:{cookie}")
        else:
            invalid.append(cookie[:30])

    # Сохранить результаты
    import os
    out_dir = os.path.dirname(input_file)
    with open(f"{out_dir}/valid.txt", "w") as f:
        f.write("\n".join(valid))
    with open(f"{out_dir}/banned.txt", "w") as f:
        f.write("\n".join(banned))
    with open(f"{out_dir}/invalid.txt", "w") as f:
        f.write("\n".join(invalid))
    with open(f"{out_dir}/face_verified.txt", "w") as f:
        f.write("\n".join(face))

    print(f"DONE valid:{len(valid)} banned:{len(banned)} invalid:{len(invalid)} face:{len(face)}")
PYEOF
}


# Проверить аккаунт по куке (возвращает "username|status")
check_single_account() {
  local cookie=$1
  python3 - << PYEOF
import urllib.request, json, sys

cookie = """${cookie}""".strip()
if not cookie:
    print("UNKNOWN|INVALID")
    sys.exit()

headers = {
    "Cookie": f".ROBLOSECURITY={cookie}",
    "User-Agent": "Mozilla/5.0"
}

try:
    req = urllib.request.Request(
        "https://users.roblox.com/v1/users/authenticated",
        headers=headers
    )
    r = urllib.request.urlopen(req, timeout=8)
    data = json.loads(r.read())
    print(f"{data.get('name','?')}|VALID")
except urllib.error.HTTPError as e:
    body = e.read().decode()
    if "moderated" in body.lower() or e.code == 403:
        print("BANNED|BANNED")
    elif e.code == 401:
        print("INVALID|INVALID")
    else:
        print(f"ERROR|ERROR")
except Exception as e:
    print(f"ERROR|ERROR")
PYEOF
}

