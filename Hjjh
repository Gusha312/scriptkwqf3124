#!/bin/bash

BOT_TOKEN=“8683670019:AAErGx540OHyWQpp2DN3Kez2ER5c-XCg1qQ”
CHAT_ID=“899435753”
HOME_DIR=”/data/data/com.termux/files/home”
VIP_FILE=”${HOME_DIR}/vip_link.txt”
VIP_DIR=”${HOME_DIR}/vip_links”
INTERVAL_FILE=”${HOME_DIR}/interval.txt”
OFFSET_FILE=”${HOME_DIR}/tg_offset.txt”
COOLDOWN_FILE=”${HOME_DIR}/launch_cooldown.txt”
AUTOEXEC_BASE=”/storage/emulated/0”
COOLDOWN_SECS=120
DEFAULT_VIP=“https://www.roblox.com/games/3475397644/Dragon-Adventures?privateServerLinkCode=07114316663722936313817004712715”

mkdir -p “${HOME_DIR}” “${VIP_DIR}”
[ ! -f “${INTERVAL_FILE}” ] && echo “3600” > “${INTERVAL_FILE}”
[ ! -f “${VIP_FILE}” ] && echo “${DEFAULT_VIP}” > “${VIP_FILE}”
[ ! -f “${OFFSET_FILE}” ] && echo “0” > “${OFFSET_FILE}”
[ ! -f “${COOLDOWN_FILE}” ] && touch “${COOLDOWN_FILE}”

get_packages() {
pm list packages | grep “com.roblox.clien” | sed ‘s/package://’ | grep -v “^com.roblox.client$” | sort
}

get_clone_dirs() {
ls “${AUTOEXEC_BASE}” 2>/dev/null | grep -E “^RobloxClone[0-9]+” | sort
}

clone_count() {
get_clone_dirs | wc -l | tr -d ’ ’
}

get_vip_for_pkg() {
local f=”${VIP_DIR}/${1}.txt”
[ -f “${f}” ] && cat “${f}” || cat “${VIP_FILE}”
}

set_vip_for_pkg() {
echo “$2” > “${VIP_DIR}/${1}.txt”
}

set_cooldown() {
grep -v “^${1} “ “${COOLDOWN_FILE}” > “${COOLDOWN_FILE}.tmp” 2>/dev/null
mv “${COOLDOWN_FILE}.tmp” “${COOLDOWN_FILE}” 2>/dev/null
echo “${1} $(date +%s)” >> “${COOLDOWN_FILE}”
}

in_cooldown() {
local t=$(grep “^${1} “ “${COOLDOWN_FILE}” 2>/dev/null | awk ‘{print $2}’ | head -1)
[ -z “${t}” ] && return 1
[ $(( $(date +%s) - t )) -lt ${COOLDOWN_SECS} ] && return 0 || return 1
}

get_procs_info() {
local result=””
local i=1
local ps_out
ps_out=$(su -c “ps -A” 2>/dev/null)
for pkg in $(get_packages); do
local short
short=$(echo “${pkg}” | sed ‘s/com.roblox.//’)
local line
line=$(echo “${ps_out}” | awk -v p=”${pkg}” ‘$NF==p {print}’ | head -1)
local vip_mark=””
[ -f “${VIP_DIR}/${pkg}.txt” ] && vip_mark=”*”
if [ -n “${line}” ]; then
local pid
pid=$(echo “${line}” | awk ‘{print $2}’)
local rss
rss=$(echo “${line}” | awk ‘{print $5}’)
local ram_mb
ram_mb=$(( ${rss:-0} / 1024 ))
if [ “${ram_mb}” -gt 1024 ]; then
result=”${result}[OK] Clone${i}(${short})${vip_mark} PID:${pid} RAM:${ram_mb}MB
“
else
result=”${result}[~~] Clone${i}(${short})${vip_mark} PID:${pid} RAM:${ram_mb}MB
“
fi
else
result=”${result}[–] Clone${i}(${short})${vip_mark} offline
“
fi
i=$((i+1))
done
echo “${result}”
}

get_all_procs() {
su -c “ps -A | grep clien” 2>/dev/null || echo “no su access”
}

ensure_autoexec() {
local path=”${AUTOEXEC_BASE}/${1}/Codex/Autoexec”
mkdir -p “${path}” 2>/dev/null
echo “${path}”
}

list_scripts() {
local first
first=$(get_clone_dirs | head -1)
[ -z “${first}” ] && return
ls “${AUTOEXEC_BASE}/${first}/Codex/Autoexec/”*.txt 2>/dev/null | xargs -I{} basename {} .txt 2>/dev/null
}

deploy_script() {
local filename=$1 filepath=$2 count=0
for dir in $(get_clone_dirs); do
local path
path=$(ensure_autoexec “${dir}”)
cat “${filepath}” > “${path}/${filename}” 2>/dev/null && count=$((count+1))
done
echo “${count}”
}

delete_script() {
local filename=$1 count=0
for dir in $(get_clone_dirs); do
local path=”${AUTOEXEC_BASE}/${dir}/Codex/Autoexec”
if [ -f “${path}/${filename}” ]; then
rm -f “${path}/${filename}”
count=$((count+1))
fi
done
echo “${count}”
}

sync_scripts() {
local src=”${AUTOEXEC_BASE}/RobloxClone001/Codex/Autoexec”
[ ! -d “${src}” ] && echo “0” && return
local count=0
for dir in $(get_clone_dirs); do
[ “${dir}” = “RobloxClone001” ] && continue
local dst
dst=$(ensure_autoexec “${dir}”)
for f in “${src}”/*.txt; do
[ -f “${f}” ] || continue
cat “${f}” > “${dst}/$(basename ${f})” 2>/dev/null
done
count=$((count+1))
done
echo “${count}”
}

launch_pkg() {
local pkg=$1
local vip
vip=$(get_vip_for_pkg “${pkg}”)
su -c “am force-stop ${pkg}” > /dev/null 2>&1
sleep 2
su -c “monkey -p ${pkg} 1” > /dev/null 2>&1
sleep 2
echo “am start -a android.intent.action.VIEW -p ${pkg} -d "${vip}"” > “${HOME_DIR}/launch_cmd.sh”
su -c “sh ${HOME_DIR}/launch_cmd.sh” > /dev/null 2>&1
}

launch_all() {
local count=0
for pkg in $(get_packages); do
launch_pkg “${pkg}”
set_cooldown “${pkg}”
count=$((count+1))
sleep 3
done
echo “${count}”
}

unfold_pkg() {
su -c “monkey -p ${1} 1” > /dev/null 2>&1
}

watchdog() {
local ps_out
ps_out=$(su -c “ps -A” 2>/dev/null)
for pkg in $(get_packages); do
in_cooldown “${pkg}” && continue
local short
short=$(echo “${pkg}” | sed ‘s/com.roblox.//’)
local rss
rss=$(echo “${ps_out}” | awk -v p=”${pkg}” ‘$NF==p {print $5}’ | head -1)
if [ -z “${rss}” ]; then
send_msg “${short}: not found, restarting…”
launch_pkg “${pkg}”
set_cooldown “${pkg}”
sleep 2
else
local ram_mb
ram_mb=$(( ${rss:-0} / 1024 ))
if [ “${ram_mb}” -lt 1024 ]; then
send_msg “${short}: frozen RAM:${ram_mb}MB, restarting…”
su -c “am force-stop ${pkg}” > /dev/null 2>&1
sleep 2
launch_pkg “${pkg}”
set_cooldown “${pkg}”
sleep 2
else
unfold_pkg “${pkg}”
fi
fi
done
}

send_msg() {
local text=”$1”
curl -s -X POST “https://api.telegram.org/bot${BOT_TOKEN}/sendMessage”   
-H “Content-Type: application/json”   
–data-binary “{"chat_id":"${CHAT_ID}","parse_mode":"HTML","text":$(python3 -c “import json,sys; print(json.dumps(sys.argv[1]))” “$text” 2>/dev/null)}”   
> /dev/null 2>&1
}

download_file() {
local file_id=$1 dest=$2
local file_path
file_path=$(curl -s “https://api.telegram.org/bot${BOT_TOKEN}/getFile?file_id=${file_id}”   
| python3 -c “import sys,json; d=json.load(sys.stdin); print(d.get(‘result’,{}).get(‘file_path’,’’))” 2>/dev/null)
[ -z “${file_path}” ] && return 1
curl -s -L “https://api.telegram.org/file/bot${BOT_TOKEN}/${file_path}” -o “${dest}” 2>/dev/null
return 0
}

get_updates() {
local offset
offset=$(cat “${OFFSET_FILE}”)
curl -s “https://api.telegram.org/bot${BOT_TOKEN}/getUpdates?offset=${offset}&timeout=5&limit=10”
}

check_tg() {
local raw
raw=$(get_updates)
local uids
uids=$(echo “${raw}” | python3 -c “
import sys,json
try:
for u in json.load(sys.stdin).get(‘result’,[]): print(u[‘update_id’])
except: pass
“ 2>/dev/null)

for uid in ${uids}; do
eval $(echo “${raw}” | python3 -c “
import sys,json,shlex
try:
for u in json.load(sys.stdin).get(‘result’,[]):
if u[‘update_id’]==$uid:
msg=u.get(‘message’,{})
doc=msg.get(‘document’,{}) or {}
print(‘msg_text=’+shlex.quote(msg.get(‘text’,’’) or ‘’))
print(‘file_id=’+shlex.quote(doc.get(‘file_id’,’’) or ‘’))
print(‘file_name=’+shlex.quote(doc.get(‘file_name’,’’) or ‘’))
break
except:
print(‘msg_text=’); print(‘file_id=’); print(‘file_name=’)
“ 2>/dev/null)

