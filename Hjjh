[ ! -f "${LAST_LAUNCH_FILE}" ] && echo "0"           > "${LAST_LAUNCH_FILE}"
[ ! -f "${COOLDOWN_FILE}" ]    && touch "${COOLDOWN_FILE}"
[ ! -f "${CRASH_FILE}" ]       && touch "${CRASH_FILE}"
[ ! -f "${ACCOUNT_CACHE}" ]    && touch "${ACCOUNT_CACHE}"

# ── Пакеты ──
get_packages() {
  pm list packages | grep "com.roblox.clien" | sed 's/package://' | grep -v "^com\.roblox\.client$" | sort
}

get_clone_dirs() {
  ls "${AUTOEXEC_BASE}" 2>/dev/null | grep -E "^RobloxClone[0-9]+" | sort
}

clone_count() { get_clone_dirs | wc -l | tr -d ' '; }

# ── VIP ──
get_vip_for_pkg() {
  local f="${VIP_DIR}/${1}.txt"
  [ -f "${f}" ] && cat "${f}" || cat "${VIP_FILE}"
}
set_vip_for_pkg() { echo "$2" > "${VIP_DIR}/${1}.txt"; }

# ── Кулдаун ──
set_cooldown() {
  grep -v "^${1} " "${COOLDOWN_FILE}" > "${COOLDOWN_FILE}.tmp" 2>/dev/null
  mv "${COOLDOWN_FILE}.tmp" "${COOLDOWN_FILE}" 2>/dev/null
  echo "${1} $(date +%s)" >> "${COOLDOWN_FILE}"
}
in_cooldown() {
  local t=$(grep "^${1} " "${COOLDOWN_FILE}" 2>/dev/null | awk '{print $2}' | head -1)
  [ -z "${t}" ] && return 1
  [ $(( $(date +%s) - t )) -lt ${COOLDOWN_SECS} ] && return 0 || return 1
}

# ── Счётчик вылетов ──
get_crash_count() {
  grep "^${1} " "${CRASH_FILE}" 2>/dev/null | awk '{print $2}' | head -1
}
inc_crash_count() {
  local count=$(get_crash_count "${1}")
  count=$(( ${count:-0} + 1 ))
  grep -v "^${1} " "${CRASH_FILE}" > "${CRASH_FILE}.tmp" 2>/dev/null
  mv "${CRASH_FILE}.tmp" "${CRASH_FILE}" 2>/dev/null
  echo "${1} ${count}" >> "${CRASH_FILE}"
  echo "${count}"
}
reset_crash_count() {
  grep -v "^${1} " "${CRASH_FILE}" > "${CRASH_FILE}.tmp" 2>/dev/null
  mv "${CRASH_FILE}.tmp" "${CRASH_FILE}" 2>/dev/null
}
is_disabled() {
  grep -q "^${1} DISABLED$" "${CRASH_FILE}" 2>/dev/null
}
disable_clone() {
  grep -v "^${1} " "${CRASH_FILE}" > "${CRASH_FILE}.tmp" 2>/dev/null
  mv "${CRASH_FILE}.tmp" "${CRASH_FILE}" 2>/dev/null
  echo "${1} DISABLED" >> "${CRASH_FILE}"
}
enable_clone() {
  grep -v "^${1} " "${CRASH_FILE}" > "${CRASH_FILE}.tmp" 2>/dev/null
  mv "${CRASH_FILE}.tmp" "${CRASH_FILE}" 2>/dev/null
}

# ── Аккаунт кэш ──
get_cached_name() {
  grep "^${1}|" "${ACCOUNT_CACHE}" 2>/dev/null | head -1 | cut -d'|' -f2
}
get_cached_status() {
  grep "^${1}|" "${ACCOUNT_CACHE}" 2>/dev/null | head -1 | cut -d'|' -f3
}
update_account_cache() {
  grep -v "^${1}|" "${ACCOUNT_CACHE}" > "${ACCOUNT_CACHE}.tmp" 2>/dev/null
  mv "${ACCOUNT_CACHE}.tmp" "${ACCOUNT_CACHE}" 2>/dev/null
  echo "${1}|${2}|${3}" >> "${ACCOUNT_CACHE}"
}

# ── Проверка аккаунта через API ──
check_single_account() {
  local cookie="$1"
  python3 -c "
import urllib.request, json, sys
cookie = sys.argv[1].strip()
if not cookie:
    print('UNKNOWN|INVALID')
    sys.exit()
headers = {'Cookie': '.ROBLOSECURITY=' + cookie, 'User-Agent': 'Mozilla/5.0'}
try:
    req = urllib.request.Request('https://users.roblox.com/v1/users/authenticated', headers=headers)
    r = urllib.request.urlopen(req, timeout=8)
    data = json.loads(r.read())
    print(data.get('name','?') + '|VALID')
except urllib.error.HTTPError as e:
    body = e.read().decode()
    if 'moderated' in body.lower() or e.code == 403:
        print('BANNED|BANNED')
    elif e.code == 401:
        print('?|INVALID')
    else:
        print('?|ERROR')
except:
    print('?|ERROR')
" "$cookie" 2>/dev/null
}

# ── Проверить все аккаунты ──
check_all_accounts() {
  local valid=0 banned=0 invalid=0 nocookie=0
  for pkg in $(get_packages); do
    local token=$(get_cookie_for_pkg "${pkg}")
    if [ -n "${token}" ]; then
      local result=$(check_single_account "${token}")
      local uname=$(echo "${result}" | cut -d'|' -f1)
      local ustatus=$(echo "${result}" | cut -d'|' -f2)
      update_account_cache "${pkg}" "${uname}" "${ustatus}"
      if [ "${ustatus}" = "BANNED" ] || [ "${ustatus}" = "INVALID" ]; then
        su -c "am force-stop ${pkg}" > /dev/null 2>&1
        disable_clone "${pkg}"
        [ "${ustatus}" = "BANNED" ] && banned=$((banned+1)) || invalid=$((invalid+1))
      else
        enable_clone "${pkg}"
        valid=$((valid+1))
      fi
    else
      update_account_cache "${pkg}" "?" "NO_COOKIE"
      nocookie=$((nocookie+1))
    fi
  done
  echo "Валид:${valid} Бан:${banned} Невалид:${invalid} НетКуки:${nocookie}"
}

# ── Процессы ──
get_procs_info() {
  local result="" i=1
  local ps_out=$(su -c "ps -A" 2>/dev/null)
  for pkg in $(get_packages); do
    local short=$(echo "${pkg}" | sed 's/com.roblox.//')
    local uname=$(get_cached_name "${pkg}")
    local ustatus=$(get_cached_status "${pkg}")
    [ -z "${uname}" ] && uname="?"

    local vip_mark=""
    [ -f "${VIP_DIR}/${pkg}.txt" ] && vip_mark="*"

    if [ "${ustatus}" = "BANNED" ]; then
      result="${result}ЗАБЛОКИРОВАН ${uname} Клон${i} ${short}
"
    elif [ "${ustatus}" = "INVALID" ]; then
      result="${result}НЕВАЛИД ${uname} Клон${i} ${short}
"
    else
      local line=$(echo "${ps_out}" | awk -v p="${pkg}" '$NF==p {print}' | head -1)
      if [ -n "${line}" ]; then
        local pid=$(echo "${line}" | awk '{print $2}')
        local rss=$(echo "${line}" | awk '{print $5}')
        local ram_mb=$(( ${rss:-0} / 1024 ))
        if [ "${ram_mb}" -gt 1024 ]; then
          result="${result}ВКЛ  ${uname} Клон${i} ${short}${vip_mark} PID:${pid} RAM:${ram_mb}MB
"
        else
          result="${result}МАЛ  ${uname} Клон${i} ${short}${vip_mark} PID:${pid} RAM:${ram_mb}MB
"
        fi
      else
        result="${result}ВЫКЛ ${uname} Клон${i} ${short}${vip_mark} офлайн
"
      fi
    fi
    i=$((i+1))
  done
  echo "${result}"
}

