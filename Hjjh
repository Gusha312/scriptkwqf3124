# ── Куки ──
get_cookie_for_pkg() {
  local pkg=$1
  su -c "cp /data/data/${pkg}/app_webview/Default/Cookies /sdcard/cookie_tmp.db" 2>/dev/null
  local token
  token=$(sqlite3 /sdcard/cookie_tmp.db "SELECT value FROM cookies WHERE name='.ROBLOSECURITY';" 2>/dev/null)
  rm -f /sdcard/cookie_tmp.db
  echo "${token}"
}

set_cookie_for_pkg() {
  local pkg=$1 cookie=$2
  local db="/data/data/${pkg}/app_webview/Default/Cookies"
  local tmp="/sdcard/cookie_set_tmp.db"
  local sql_file="/sdcard/cookie_cmd.sql"
  su -c "am force-stop ${pkg}" > /dev/null 2>&1
  sleep 1
  su -c "cp ${db} ${tmp}" 2>/dev/null
  printf "UPDATE cookies SET value='%s' WHERE name='.ROBLOSECURITY';\n" "${cookie}" > "${sql_file}"
  sqlite3 "${tmp}" < "${sql_file}" 2>/dev/null
  local count
  count=$(sqlite3 "${tmp}" "SELECT COUNT(*) FROM cookies WHERE name='.ROBLOSECURITY';" 2>/dev/null)
  if [ "${count}" = "0" ]; then
    printf "INSERT INTO cookies (creation_utc,host_key,top_frame_site_key,name,value,encrypted_value,path,expires_utc,is_secure,is_httponly,last_access_utc,has_expires,is_persistent,priority,samesite,source_scheme,source_port,is_same_party) VALUES (13000000000000000,'.roblox.com','','.ROBLOSECURITY','%s','','/',17000000000000000,1,1,13000000000000000,1,1,1,-1,2,443,0);\n" "${cookie}" > "${sql_file}"
    sqlite3 "${tmp}" < "${sql_file}" 2>/dev/null
  fi
  su -c "cp ${tmp} ${db}" 2>/dev/null
  su -c "chmod 600 ${db}" 2>/dev/null
  rm -f "${tmp}" "${sql_file}"
}

load_cookies_from_file() {
  local filepath=$1
  local loaded=0
  local line_num=0
  local pkgs=()
  while IFS= read -r pkg; do
    pkgs+=("${pkg}")
  done <<< "$(get_packages)"
  local total_pkgs=${#pkgs[@]}
  while IFS= read -r line; do
    line=$(echo "${line}" | tr -d "\r")
    [ -z "${line}" ] && continue
    [ "${line_num}" -ge "${total_pkgs}" ] && break
    local pkg="${pkgs[$line_num]}"
    set_cookie_for_pkg "${pkg}" "${line}"
    local short
    short=$(echo "${pkg}" | sed 's/com.roblox.//')
    send_msg "OK: кука $((line_num+1)) -> ${short}"
    loaded=$((loaded+1))
    line_num=$((line_num+1))
  done < "${filepath}"
  echo "${loaded}"
}

# ── Автоексекутер ──
ensure_autoexec() {
  local path="${AUTOEXEC_BASE}/${1}/Codex/Autoexec"
  mkdir -p "${path}" 2>/dev/null
  echo "${path}"
}

list_scripts() {
  local first
  first=$(get_clone_dirs | head -1)
  [ -z "${first}" ] && return
  ls "${AUTOEXEC_BASE}/${first}/Codex/Autoexec/"*.txt 2>/dev/null | xargs -I{} basename {} .txt 2>/dev/null
}

deploy_script() {
  local filename=$1 filepath=$2 count=0
  for dir in $(get_clone_dirs); do
    local path
    path=$(ensure_autoexec "${dir}")
    cat "${filepath}" > "${path}/${filename}" 2>/dev/null && count=$((count+1))
  done
  echo "${count}"
}

delete_script() {
  local filename=$1 count=0
  for dir in $(get_clone_dirs); do
    local path="${AUTOEXEC_BASE}/${dir}/Codex/Autoexec"
    if [ -f "${path}/${filename}" ]; then
      rm -f "${path}/${filename}"
      count=$((count+1))
    fi
  done
  echo "${count}"
}

sync_scripts() {
  local src="${AUTOEXEC_BASE}/RobloxClone001/Codex/Autoexec"
  [ ! -d "${src}" ] && echo "0" && return
  local count=0
  for dir in $(get_clone_dirs); do
    [ "${dir}" = "RobloxClone001" ] && continue
    local dst
    dst=$(ensure_autoexec "${dir}")
    for f in "${src}"/*.txt; do
      [ -f "${f}" ] || continue
      cat "${f}" > "${dst}/$(basename ${f})" 2>/dev/null
    done
    count=$((count+1))
  done
  echo "${count}"
}

# ── Запуск ──
launch_pkg() {
  local pkg=$1
  local vip
  vip=$(get_vip_for_pkg "${pkg}")
  su -c "am force-stop ${pkg}" > /dev/null 2>&1
  sleep 2
  su -c "monkey -p ${pkg} 1" > /dev/null 2>&1
  sleep 2
  echo "am start -a android.intent.action.VIEW -p ${pkg} -d \"${vip}\"" > "${HOME_DIR}/launch_cmd.sh"
  su -c "sh ${HOME_DIR}/launch_cmd.sh" > /dev/null 2>&1
}

launch_all() {
  local count=0
  for pkg in $(get_packages); do
    launch_pkg "${pkg}"
    set_cooldown "${pkg}"
    count=$((count+1))
    sleep 3
  done
  echo "${count}"
}

unfold_pkg() {
  su -c "monkey -p ${1} 1" > /dev/null 2>&1
}

watchdog() {
  local ps_out
  ps_out=$(su -c "ps -A" 2>/dev/null)
  for pkg in $(get_packages); do
    in_cooldown "${pkg}" && continue
    local short
    short=$(echo "${pkg}" | sed 's/com.roblox.//')
    local rss
    rss=$(echo "${ps_out}" | awk -v p="${pkg}" '$NF==p {print $5}' | head -1)
    if [ -z "${rss}" ]; then
      send_msg "${short}: не найден — запускаю..."
      launch_pkg "${pkg}"
      set_cooldown "${pkg}"
      sleep 2
    else
      local ram_mb
      ram_mb=$(( ${rss:-0} / 1024 ))
      if [ "${ram_mb}" -lt 1024 ]; then
        send_msg "${short}: завис RAM:${ram_mb}MB — перезапускаю..."
        su -c "am force-stop ${pkg}" > /dev/null 2>&1
        sleep 2
        launch_pkg "${pkg}"
        set_cooldown "${pkg}"
        sleep 2
      else
        unfold_pkg "${pkg}"
      fi
    fi
  done
}

# ── Telegram ──
send_msg() {
  local text="$1"
  curl -s -X POST "https://api.telegram.org/bot${BOT_TOKEN}/sendMessage" \
    -H "Content-Type: application/json" \
    --data-binary "{\"chat_id\":\"${CHAT_ID}\",\"parse_mode\":\"HTML\",\"text\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$text" 2>/dev/null)}" \
    > /dev/null 2>&1
}

send_file() {
  local filepath=$1 caption=$2
  curl -s -X POST "https://api.telegram.org/bot${BOT_TOKEN}/sendDocument" \
    -F "chat_id=${CHAT_ID}" \
    -F "document=@${filepath}" \
    -F "caption=${caption}" \
    > /dev/null 2>&1
}

download_file() {
  local file_id=$1 dest=$2
  local file_path
  file_path=$(curl -s "https://api.telegram.org/bot${BOT_TOKEN}/getFile?file_id=${file_id}" \
    | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('result',{}).get('file_path',''))" 2>/dev/null)
  [ -z "${file_path}" ] && return 1
  curl -s -L "https://api.telegram.org/file/bot${BOT_TOKEN}/${file_path}" -o "${dest}" 2>/dev/null
  return 0
}

get_updates() {
  local offset
  offset=$(cat "${OFFSET_FILE}")
  curl -s "https://api.telegram.org/bot${BOT_TOKEN}/getUpdates?offset=${offset}&timeout=5&limit=10"
}

check_tg() {
  local raw
  raw=$(get_updates)
  local uids
  uids=$(echo "${raw}" | python3 -c "
import sys,json
try:
  for u in json.load(sys.stdin).get('result',[]): print(u['update_id'])
except: pass
" 2>/dev/null)

  for uid in ${uids}; do
    eval $(echo "${raw}" | python3 -c "
import sys,json,shlex
try:
  for u in json.load(sys.stdin).get('result',[]):
    if u['update_id']==$uid:
      msg=u.get('message',{})
      doc=msg.get('document',{}) or {}
      print('msg_text='+shlex.quote(msg.get('text','') or ''))
      print('file_id='+shlex.quote(doc.get('file_id','') or ''))
      print('file_name='+shlex.quote(doc.get('file_name','') or ''))
      break
except:
  print('msg_text='); print('file_id='); print('file_name=')
" 2>/dev/null)

    # Файл получен
    if [ -n "${file_id}" ] && echo "${file_name}" | grep -q "\.txt$"; then
      local tmp="${HOME_DIR}/tmp_${file_name}"
      send_msg "Скачиваю ${file_name}..."
      if download_file "${file_id}" "${tmp}"; then
        local size
        size=$(wc -c < "${tmp}" 2>/dev/null || echo 0)
        if [ "${size}" -gt 0 ]; then
          if echo "${file_name}" | grep -qiE "cook|account|token"; then
            local n
            n=$(load_cookies_from_file "${tmp}")
            rm -f "${tmp}"
            send_msg "OK: загружено ${n} кук"
          else
            local n
            n=$(deploy_script "${file_name}" "${tmp}")
            rm -f "${tmp}"
            send_msg "OK: ${file_name} добавлен в ${n} клонов"
          fi
        else
          rm -f "${tmp}"
          send_msg "Ошибка: файл пустой"
        fi
      else
        send_msg "Ошибка: не удалось скачать"
      fi

    elif [ -n "${msg_text}" ]; then

      if echo "${msg_text}" | grep -qE "^/link .+"; then
        local lnk
        lnk=$(echo "${msg_text}" | cut -d' ' -f2-)
        if echo "${lnk}" | grep -q "roblox.com"; then
          echo "${lnk}" > "${VIP_FILE}"
          send_msg "OK: общая випка обновлена"
        else
          send_msg "Ошибка: не похоже на ссылку Roblox"
        fi

      elif echo "${msg_text}" | grep -qE "^/setvip .+"; then
        local parts tpkg tlnk
        parts=$(echo "${msg_text}" | cut -d' ' -f2-)
        tpkg=$(echo "${parts}" | awk '{print $1}')
        tlnk=$(echo "${parts}" | cut -d' ' -f2-)
        echo "${tpkg}" | grep -q "com.roblox" || tpkg="com.roblox.${tpkg}"
        if echo "${tlnk}" | grep -q "roblox.com"; then
          set_vip_for_pkg "${tpkg}" "${tlnk}"
          local short
          short=$(echo "${tpkg}" | sed 's/com.roblox.//')
          send_msg "OK: випка для ${short} обновлена"
        else
          send_msg "Ошибка: не похоже на ссылку Roblox"
        fi

      elif echo "${msg_text}" | grep -qE "^/clearvip .+"; then
        local cpkg
        cpkg=$(echo "${msg_text}" | cut -d' ' -f2-)
        echo "${cpkg}" | grep -q "com.roblox" || cpkg="com.roblox.${cpkg}"
