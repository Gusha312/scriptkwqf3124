-- [[ ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ]]
local function formatNum(v)
    return tostring(v or 0):reverse():gsub("(%d%d%d)", "%1."):reverse():gsub("^%.", "")
end

local function setFpsCap(fps)
    if type(setfpscap) == "function" then pcall(setfpscap, fps) end
end

UserInputService.WindowFocused:Connect(function()
    if RENDER then RunService:Set3dRenderingEnabled(true) end
    setFpsCap(MAX_FPS)
end)
UserInputService.WindowFocusReleased:Connect(function()
    if RENDER then RunService:Set3dRenderingEnabled(false) end
    setFpsCap(MIN_FPS)
end)

local function waitForData(timeout)
    timeout = timeout or 30
    local start = tick()
    while not localPlayer:FindFirstChild("Data") do
        if tick() - start > timeout then return false end
        task.wait(0.5)
    end
    return true
end

-- [[ ДИСКОРД ВЕБХУК ]]
local lastSentStats = {}
local function sendDiscordWebhook(force, customMsg)
    if not waitForData(5) then return end
    local data = localPlayer.Data
    if not data then return end

    local function getItem(name)
        local item = data:FindFirstChild("Items") and data.Items:FindFirstChild(name)
        return item and formatNum(item.Value) or "0"
    end

    local shooms = formatNum(data.Coins.Value)
    local raised = data:FindFirstChild("MarketStalls") and data.MarketStalls:FindFirstChild("ShoomsRaised") and formatNum(data.MarketStalls.ShoomsRaised.Value) or "0"
    local playerCount = #Players:GetPlayers()
    local timeStr = os.date("%H:%M:%S")
    local jobId = game.JobId

    local newHash = shooms .. raised .. playerCount
    if not force and newHash == lastSentStats.hash then return end
    lastSentStats.hash = newHash

    local statsText = customMsg or string.format(
        "**ОТЧЁТ ПО СЕРВЕРУ**\n" ..
        "👤 **Ник:** %s (@%s)\n" ..
        "🍄 **Грибов на счету:** %s\n" ..
        "🏪 **Заработано с лавок:** %s\n" ..
        "🔁 **Токенов Revive:** %s\n" ..
        "🌌 **Галактических:** %s\n" ..
        "👥 **Игроков:** %d\n" ..
        "🆔 **Server:** %s\n" ..
        "⏰ **Время:** %s",
        localPlayer.DisplayName,
        localPlayer.Name,
        shooms,
        raised,
        getItem("CreatureReviveToken"),
        getItem("GalaxyExplorerGachaToken"),
        playerCount,
        jobId,
        timeStr
    )

    pcall(function()
        request({
            Url = DISCORD_WEBHOOK,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({content = statsText})
        })
    end)
end

-- [[ ПОИСК СЕРВЕРА ]]
local function findBestServer()
    local url = "https://games.roblox.com/v1/games/" .. TRADE_WORLD_ID .. "/servers/Public?limit=100"
    local success, response = pcall(HttpService.GetAsync, HttpService, url, true)
    if not success then return nil end

    local data = HttpService:JSONDecode(response)
    if not data or not data.data then return nil end

    local fresh = {}
    for _, s in ipairs(data.data) do
        if not visitedServers[s.id] then table.insert(fresh, s) end
    end
    if #fresh == 0 then
        visitedServers = {}
        fresh = data.data
    end

    table.sort(fresh, function(a,b) return a.playing > b.playing end)

    local selected
    if SERVER_SELECTION_MODE == "top1" then selected = fresh[1]
    elseif SERVER_SELECTION_MODE == "top2" then selected = fresh[2]
    elseif SERVER_SELECTION_MODE == "random_top5" then
        local top = math.min(5, #fresh)
        if top >= 1 then selected = fresh[math.random(1, top)] end
    else selected = fresh[1] end

    if selected then
        visitedServers[selected.id] = true
        print("✅ Выбран сервер: " .. selected.playing .. " игроков, ID: " .. selected.id)
        return selected.id
    end
    return nil
end

local function joinServerById(jobId)
    if not jobId then return false end
    local ok = pcall(TeleportService.TeleportToPlaceInstance, TeleportService, TRADE_WORLD_ID, jobId, localPlayer)
    return ok
end

-- [[ ЗАХВАТ СТОЕК ]]
local function getAvailableStallAnchors()
    local stalls = {}
    local interactable = workspace:FindFirstChild("Interactable")
    if not interactable then return stalls end
    local stallsFolder = interactable:FindFirstChild("MarketStalls")
    if not stallsFolder then return stalls end
    for _, model in pairs(stallsFolder:GetChildren()) do
        if model:IsA("Model") and model.Name:match("MarketStall") then
            local anchor = model:FindFirstChild("AnchorPart")
            if anchor and anchor:IsA("BasePart") then
                table.insert(stalls, anchor)
            end
        end
    end
    return stalls
end

local function claimStallsForever()
    if currentPlaceId ~= TRADE_WORLD_ID then return end
    local MarketRemotes = ReplicatedStorage:WaitForChild("Remotes", 10)
    if not MarketRemotes then return end
    local ClaimStallRemote = MarketRemotes:WaitForChild("ClaimStall", 10)
    if not ClaimStallRemote then return end

    while true do
        pcall(function()
            local coins = localPlayer.Data.Coins.Value
            if coins >= COINS_LIMIT then return end
        end)
        local anchors = getAvailableStallAnchors()
        for _, anchor in ipairs(anchors) do
            pcall(function() ClaimStallRemote:FireServer(anchor) end)
        end
        task.wait(CLAIM_DELAY)
    end
end

-- [[ ПЕРЕКУПСТВО ]]
local function getActiveListings()
    local market = localPlayer:FindFirstChild("Data") and localPlayer.Data:FindFirstChild("MarketStalls")
    if not market then return {} end
    local list = {}
    for i = 1, MAX_LISTINGS do
        local slot = market:FindFirstChild("Listing"..i)
        if slot and slot:IsA("Folder") then
            local item = slot:FindFirstChild("ItemName")
            local price = slot:FindFirstChild("Price")
            local amount = slot:FindFirstChild("Amount")
            local ltype = slot:FindFirstChild("ListingType")
            if item and price and amount and ltype then
                table.insert(list, {
                    idx = i,
                    item = item.Value,
                    price = price.Value,
                    amount = amount.Value,
                    ltype = ltype.Value
                })
            end
        end
    end
    return list
end

local function removeListing(idx)
    pcall(function()
        ReplicatedStorage.Remotes.RemoveStallItem:FireServer(idx)
    end)
end

local function createListing(itemName, amount, price, ltype)
    local remote = ltype == "Buying" and ReplicatedStorage.Remotes.ListPurchaseItem or ReplicatedStorage.Remotes.ListStallItem
    pcall(function() remote:FireServer(itemName, amount, price) end)
end

local function flipperLoop()
    while true do
        task.wait(FLIP_CHECK_DELAY or 2)
        if game.PlaceId ~= TRADE_WORLD_ID then break end
        if not localPlayer:FindFirstChild("Data") then continue end

        local data = localPlayer.Data
        local coins = data.Coins and data.Coins.Value or 0
        local availableCoins = math.max(0, coins - MIN_COINS_RESERVE)
        local listings = getActiveListings()

        -- Удаляем неактуальные листинги
        for _, ls in ipairs(listings) do
            local valid = false
            for _, cfg in ipairs(FLIP_ITEMS) do
                if ls.item == cfg.itemName then
                    if (ls.ltype == "Buying" and ls.price == cfg.buyPrice) or (ls.ltype == "Selling" and ls.price == cfg.sellPrice) then
                        valid = true
                    end
                    break
                end
            end
            if not valid or ls.amount <= 0 then
                removeListing(ls.idx)
            end
        end

        listings = getActiveListings()
        local freeSlots = MAX_LISTINGS - #listings
        if freeSlots <= 0 then continue end

        for _, cfg in ipairs(FLIP_ITEMS) do
            if freeSlots <= 0 then break end
            local itemCount = data:FindFirstChild("Items") and data.Items:FindFirstChild(cfg.itemName) and data.Items[cfg.itemName].Value or 0

            local buyListing, sellListing
            for _, ls in ipairs(listings) do
                if ls.item == cfg.itemName then
                    if ls.ltype == "Buying" then buyListing = ls
                    elseif ls.ltype == "Selling" then sellListing = ls end
                end
            end

            local inBuy = buyListing and buyListing.amount or 0
            local inSell = sellListing and sellListing.amount or 0

            -- Продажа
            if itemCount > 0 and not sellListing and freeSlots > 0 then
                local toSell = itemCount
                if cfg.maxTotal then
                    local maxSell = cfg.maxTotal - inSell
                    toSell = math.min(toSell, maxSell)
                end
                if toSell > 0 then
                    createListing(cfg.itemName, toSell, cfg.sellPrice, "Selling")
                    freeSlots = freeSlots - 1
                end
            -- Покупка
            elseif itemCount == 0 and not buyListing and freeSlots > 0 then
                local maxByCoins = math.floor(availableCoins / cfg.buyPrice)
                if maxByCoins > 0 then
                    local toBuy = maxByCoins
                    if cfg.maxTotal then
                        toBuy = math.min(toBuy, cfg.maxTotal - (inBuy - inSell))
                    end
                    if toBuy > 0 then
                        createListing(cfg.itemName, toBuy, cfg.buyPrice, "Buying")
                        freeSlots = freeSlots - 1
                    end
                end
            end
        end
    end
end

-- [[ КОНТРОЛЬ ОНЛАЙНА ]]
local function serverPlayerCheck()
    while true do
        task.wait(CHECK_INTERVAL)
        if game.PlaceId ~= TRADE_WORLD_ID then break end
        local playerCount = #Players:GetPlayers()
        if playerCount <= MIN_PLAYERS_THRESHOLD then
            print("📉 Мало игроков ("..playerCount.."). Ухожу в обычный мир...")
            sendDiscordWebhook(true, "⚠️ Сервер пустеет ("..playerCount.." чел). Рестарт сервера...")
            task.wait(1)
            pcall(TeleportService.Teleport, TeleportService, NORMAL_WORLD_ID, localPlayer)
            break
        end
    end
end

-- [[ АВТОПЕРЕЗАХОД ПО ТАЙМЕРУ ]]
local function autoRejoinLoop()
    if REJOIN_INTERVAL <= 0 then return end
    while true do
        task.wait(REJOIN_INTERVAL)
        if game.PlaceId == TRADE_WORLD_ID then
            print("🔄 Плановый реджоин на новый сервер...")
            sendDiscordWebhook(true, "🔁 Плановый перезаход на свежий сервер для лавок.")
            task.wait(1)
            local best = findBestServer()
            if best then
                joinServerById(best)
            else
                pcall(TeleportService.Teleport, TeleportService, TRADE_WORLD_ID, localPlayer)
            end
        end
    end
end

-- [[ АНТИ-АФК ]]
local function setupAntiAFK()
    task.spawn(function()
        while true do
            task.wait(25)
            if localPlayer.Character and localPlayer.Character:FindFirstChild("Humanoid") then
                localPlayer.Character.Humanoid:Move(Vector3.new())
            end
        end
    end)
end

-- [[ ГЛАВНАЯ ]]
local function main()
    setFpsCap(MAX_FPS)
    setupAntiAFK()

    if currentPlaceId == NORMAL_WORLD_ID then
        if not waitForData(10) then return end
        if localPlayer.Data.Coins.Value >= COINS_LIMIT then
            sendDiscordWebhook(true, "🛑 Лимит 7М достигнут. Бот в простое.")
            return
        end
        task.wait(8)
        local best = findBestServer()
        if best then joinServerById(best)
        else pcall(TeleportService.Teleport, TeleportService, TRADE_WORLD_ID, localPlayer) end
    elseif currentPlaceId == TRADE_WORLD_ID then
        sendDiscordWebhook(true)
        task.spawn(claimStallsForever)
        task.spawn(serverPlayerCheck)
        task.spawn(flipperLoop)
        task.spawn(autoRejoinLoop)
        task.spawn(function()
            while true do
                task.wait(SEND_STATS_INTERVAL)
                sendDiscordWebhook()
            end
        end)
    else
        print("⚠️ Неизвестный PlaceId:", currentPlaceId)
        task.wait(10)
    end
end

pcall(main)
