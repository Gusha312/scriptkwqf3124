    -- УСКОРЕННОЕ ВЫПОЛНЕНИЕ МИССИИ AttackOrHealCreatureOrNPC
    function completeAttackOrHealMission(regionName)
        print("🔄 Выполняем AttackOrHealCreatureOrNPC в регионе: " .. regionName)
        
        changeRegion(regionName)
        
        if teleportToRandomNPCSpawn() then
            wait(1) -- Уменьшено
            changeRegion(regionName)
        end
        
        local missionCompleted = false
        local attempts = 0
        
        while not missionCompleted and attempts < 60 do -- Уменьшено с 100 до 60
            attempts = attempts + 1
            
            if attempts % 15 == 0 then -- Еда/вода каждые 15 попыток
                useFoodAndWater()
            end
            
            attackNPC()
            
            -- Проверяем выполнение миссии
            local regionFolder = regionMissions:FindFirstChild(regionName)
            if regionFolder then
                local attackMission = regionFolder:FindFirstChild("AttackOrHealCreatureOrNPC")
                if attackMission and attackMission.Value then
                    missionCompleted = true
                    print("✅ AttackOrHealCreatureOrNPC выполнена в регионе " .. regionName)
                    break
                end
            end
            
            if not missionCompleted then
                wait(0.3) -- Уменьшено с 0.5 до 0.3
            end
        end
        
        return missionCompleted
    end
    
    -- УСКОРЕННОЕ ВЫПОЛНЕНИЕ МИССИИ DistanceTravelled
    function completeDistanceTravelledMission(regionName)
        print("🔄 Выполняем DistanceTravelled в регионе: " .. regionName)
        
        changeRegion(regionName)
        
        local missionCompleted = false
        local attempts = 0
        
        while not missionCompleted and attempts < 50 do -- Уменьшено с 100 до 50
            attempts = attempts + 1
            
            useFoodAndWater()
            
            for i, pos in ipairs(teleportPositions) do
                teleportPlayer(pos)
                wait(1) -- Уменьшено с 2 до 1
                
                if i == 1 then
                    changeRegion(regionName)
                end
                
                -- Проверяем выполнение миссии
                local regionFolder = regionMissions:FindFirstChild(regionName)
                if regionFolder then
                    local distanceMission = regionFolder:FindFirstChild("DistanceTravelled")
                    if distanceMission and distanceMission.Value then
                        missionCompleted = true
                        print("✅ DistanceTravelled выполнена в регионе " .. regionName)
                        break
                    end
                end
                
                if missionCompleted then
                    break
                end
            end
            
            if not missionCompleted then
                print("⏳ DistanceTravelled... (" .. attempts .. "/50)")
            end
        end
        
        return missionCompleted
    end
    
    -- УСКОРЕННОЕ ВЫПОЛНЕНИЕ МИССИИ TimePlayed
    function completeTimePlayedMission(regionName)
        print("🔄 Выполняем TimePlayed в регионе: " .. regionName)
        print("⏰ Ожидаем...")
        
        changeRegion(regionName)
        
        local missionCompleted = false
        local checkCount = 0
        
        while not missionCompleted do
            checkCount = checkCount + 1
            
            if checkCount % 3 == 0 then -- Еда/вода каждые 3 проверки
                useFoodAndWater()
            end
            
            -- Проверяем, не появились ли другие миссии
            local otherMissions = getUncompletedMissions()
            for _, mission in ipairs(otherMissions) do
                if mission.missionName ~= "TimePlayed" then
                    print("⚠️ Появились другие миссии! Прерываем TimePlayed")
                    return false
                end
            end
            
            local regionFolder = regionMissions:FindFirstChild(regionName)
            if regionFolder then
                local timeMission = regionFolder:FindFirstChild("TimePlayed")
                if timeMission and timeMission.Value then
                    missionCompleted = true
                    print("✅ TimePlayed выполнена в регионе " .. regionName)
                    break
                else
                    if checkCount % 5 == 0 then
                        print("⏳ TimePlayed... (" .. checkCount .. " проверок)")
                    end
                end
            end
            
            wait(5) -- Уменьшено с 10 до 5
        end
        
        return missionCompleted
    end
    
    -- УСКОРЕННАЯ ОСНОВНАЯ ФУНКЦИЯ ФАРМА
    function autoCompleteAllMissions()
        print("🚀 Запуск выполнения невыполненных миссий (ускоренный)...")
        
        while true do
            -- Проверяем смерть во время фарма
            if checkDeathDuringFarm() then
                print("🔄 После смерти продолжаем фарм...")
                wait(3) -- Уменьшено
            end
            
            local uncompleted = getUncompletedMissions()
            
            if #uncompleted == 0 then
                print("🎉 Все миссии выполнены!")
                wait(5) -- Уменьшено
            else
                print("📋 Найдено невыполненных миссий: " .. #uncompleted)
                
                for i, mission in ipairs(uncompleted) do
                    print("\n🎯 Миссия " .. i .. "/" .. #uncompleted .. ": " .. mission.regionName .. " - " .. mission.missionName)
                    
                    local success = false
                    
                    if mission.missionName == "Sniff" then
                        success = completeSniffMission(mission.regionName)
                    elseif mission.missionName == "ConcealScent" then
                        success = completeConcealScentMission(mission.regionName)
                    elseif mission.missionName == "EatFoodDrinkWater" then
                        success = completeEatFoodDrinkWaterMission(mission.regionName)
                    elseif mission.missionName == "AttackOrHealCreatureOrNPC" then
                        success = completeAttackOrHealMission(mission.regionName)
                    elseif mission.missionName == "DistanceTravelled" then
                        success = completeDistanceTravelledMission(mission.regionName)
                    elseif mission.missionName == "TimePlayed" then
                        success = completeTimePlayedMission(mission.regionName)
                    else
                        print("❓ Неизвестный тип миссии: " .. mission.missionName)
                    end
                    
                    if success then
                        print("✅ Успешно выполнено!")
                    else
                        print("❌ Не удалось выполнить")
                    end
                    
                    wait(0.5) -- Уменьшено
                end
                
                print("\n🔄 Проверяем наличие новых миссий...")
                wait(3) -- Уменьшено
            end
        end
    end
    
    -- Запускаем периодические запросы в отдельном потоке
    spawn(periodicRemoteRequests)
    
    -- Запускаем фарм миссий
    autoCompleteAllMissions()
end

