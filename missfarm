local VirtualInputManager = game:GetService("VirtualInputManager")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

wait(3) -- Уменьшенный стартовый КД
print("🎮 Запуск скрипта (ускоренная версия)")

-- ========== ФУНКЦИИ ДЛЯ КЛИКА ==========
-- Функция для клика по координатам
local function clickAtPosition(posX, posY)
    VirtualInputManager:SendMouseButtonEvent(posX, posY, 0, true, game, 1)
    wait(0.05) -- Уменьшенный КД
    VirtualInputManager:SendMouseButtonEvent(posX, posY, 0, false, game, 1)
end

-- Функция клика в центре экрана
local function click()
    local screen = workspace.CurrentCamera.ViewportSize
    clickAtPosition(screen.X/2, screen.Y/2)
end

-- ========== ФУНКЦИЯ ДЛЯ ПРОВЕРКИ СМЕРТИ ВО ВРЕМЯ ФАРМА ==========
local function checkDeathDuringFarm()
    local player = game.Players.LocalPlayer
    local playerGui = player.PlayerGui
    
    local deathGui = playerGui:FindFirstChild("DeathGui")
    if deathGui and deathGui.Enabled == true then
        print("\n💀 ОБНАРУЖЕНА СМЕРТЬ ВО ВРЕМЯ ФАРМА!")
        
        wait(8) -- Уменьшенный КД
        
        local returnButton = deathGui.ContainerFrame.BottomFrame.ButtonsFrame.Return.UpperLabel
        
        -- Кликаем по Return
        if returnButton then
            click()
            wait(0.3)
            click()
        else
            click()
            wait(0.3)
            click()
        end
        
        -- Ждем пока GUI полностью закроется
        wait(3) -- Уменьшенный КД
        
        -- 1. ВЫЗЫВАЕМ DESPAWNREMOTE ДЛЯ ВЫХОДА
        print("🚪 Вызываем DespawnRemote для выхода...")
        local despawnSuccess, despawnError = pcall(function()
            game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("DespawnRemote"):InvokeServer()
            return true
        end)
        
        if despawnSuccess then
            print("✅ DespawnRemote успешно вызван")
        else
            print("❌ Ошибка DespawnRemote: " .. tostring(despawnError))
        end
        
        wait(2) -- Уменьшенный КД
        
        -- 2. УДАЛЕНИЕ СЛОТА
        print("🗑️ Удаляем слот Slot1...")
        local deleteSuccess, deleteError = pcall(function()
            local args = {"Slot1", false}
            ReplicatedStorage.Remotes.DeleteSlotRemote:InvokeServer(unpack(args))
            return true
        end)
        
        if deleteSuccess then
            print("✅ Запрос удаления отправлен")
        else
            print("❌ Ошибка удаления: " .. tostring(deleteError))
        end
        
        wait(3) -- Уменьшенный КД
        
        -- 3. СОЗДАНИЕ НОВОГО СЛОТА
        print("➕ Создаем новый слот Sochuri...")
        local createSuccess, createError = pcall(function()
            local args = {"Sochuri"}
            ReplicatedStorage.Remotes.CreateSlotRemote:InvokeServer(unpack(args))
            return true
        end)
        
        if createSuccess then
            print("✅ Запрос создания отправлен")
        else
            print("❌ Ошибка создания: " .. tostring(createError))
        end
        
        wait(3) -- Уменьшенный КД
        
        -- 4. ВЫПОЛНЯЕМ КЛИКИ ДЛЯ ВОЗОБНОВЛЕНИЯ ИГРЫ
        print("🔄 Выполняем клики для возобновления игры...")
        wait(2)
        click()
        wait(1)
        click()
        
        print("✅ Обработка смерти завершена!")
        return true
    end
    
    return false
end

