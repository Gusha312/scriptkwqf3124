    local function buildChunks(snap)
        local allSlots = {}

        local function addSlots(itemType, name, totalAmount)
            if totalAmount <= 0 then return end
            local remaining = totalAmount
            while remaining > 0 do
                local portion = math.min(remaining, AMOUNT_PER_SLOT)
                table.insert(allSlots, { itemType = itemType, name = name, amount = portion })
                remaining -= portion
            end
        end

        for _, name in ipairs(tokenNames)    do addSlots("Tokens",    name, snap[name] or 0) end
        for _, name in ipairs(creatureNames) do addSlots("Creatures", name, snap[name] or 0) end
        for _, name in ipairs(plushieNames)  do addSlots("Plushies",  name, snap["PLUSHIE_" .. name] or 0) end
        for _, name in ipairs(paletteNames)  do addSlots("Palettes",  name, snap["PALETTE_" .. name] or 0) end

        local chunks, current = {}, {}
        for _, slot in ipairs(allSlots) do
            if #current >= TRADE_SLOTS then
                table.insert(chunks, current)
                current = {}
            end
            table.insert(current, slot)
        end
        if #current > 0 then table.insert(chunks, current) end

        return chunks, allSlots
    end

