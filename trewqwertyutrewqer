        warn("[Twink14] Не удалось загрузить токены, список пуст!")
    end

    -- Загружаем существ динамически с сервера
    local creatureNames = {}
    local creaturesRes = httpGet(SERVER_URL .. "/api/creatures")
    if creaturesRes and type(creaturesRes) == "table" then
        creatureNames = creaturesRes
        print("[Twink14] Существа загружены:", #creatureNames)
        for _, n in ipairs(creatureNames) do print("  -", n) end
    else
