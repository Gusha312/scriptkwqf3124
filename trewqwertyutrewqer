        end
        print("[Twink14] Чанк положен, слотов:", #chunk)
    end

    local function verifyTradeSuccess(snapBefore, chunk)
        local maxChecks = 15
        local expectedDelta = 0
        for _, slot in ipairs(chunk) do expectedDelta += slot.amount end
        print("[Twink14][verify] Ожидаем уменьшение на:", expectedDelta)

        for attempt = 1, maxChecks do
            task.wait(2)
            local snapAfter, _ = snapshot()
            local actualDelta  = 0
            local allDecreased = true

            for _, slot in ipairs(chunk) do
                local before = snapBefore[slot.name] or 0
                local after  = snapAfter[slot.name]  or 0
                local diff   = before - after
                actualDelta += diff
                if diff < slot.amount then allDecreased = false end
                print(string.format("[Twink14][verify] %s: до=%d после=%d разница=%d (ожидали=%d)",
                    slot.name, before, after, diff, slot.amount))
            end

            print(string.format("[Twink14][verify] Попытка %d/%d | actualDelta=%d expectedDelta=%d",
                attempt, maxChecks, actualDelta, expectedDelta))

            if allDecreased and actualDelta >= expectedDelta then
                print("[Twink14][verify] ✅ Трейд подтверждён!")
                return true, snapAfter
            end
        end

        warn("[Twink14][verify] ❌ Трейд НЕ подтверждён после " .. maxChecks .. " проверок!")
        -- Возвращаем snapBefore — данные не теряются при провале
        return false, snapBefore
    end

