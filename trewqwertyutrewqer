        local accWait = 0
        while tradeGui and not tradeGui.Enabled and accWait < 60 do
            pcall(function()
                Players:WaitForChild(mainName, 10)
                    :WaitForChild("Remotes"):WaitForChild("TradeRequestRemote"):FireServer("AcceptRequest")
            end)
            task.wait(2)
            accWait += 2
        end

        if not tradeGui or not tradeGui.Enabled then
            warn("[Twink14] Трейд не открылся, попытка #" .. attempt)
            task.wait(5)
            continue
        end
        print("[Twink14] Трейд принят, TradeGui открылся")
        task.wait(2)

        local tradeRem, remWait = nil, 0
        repeat
            task.wait(1); remWait += 1
            local remotes = ReplicatedStorage:FindFirstChild("Remotes")
            if remotes then tradeRem = remotes:FindFirstChild(tradeRemoteName) end
        until tradeRem or remWait >= 30

        if not tradeRem then
            warn("[Twink14] TradeRemote не найден, попытка #" .. attempt)
            task.wait(5)
            continue
        end
        print("[Twink14] TradeRemote найден, кладём предметы...")

        putItemsInTrade(tradeRem, currentSnap)

        print("[Twink14] Принимаем трейд...")
        task.spawn(function()
            local ok, err = pcall(function()
                tradeRem:InvokeServer(unpack({"AcceptTrade"}))
            end)
            print("[Twink14] AcceptTrade завершён:", ok and "OK" or tostring(err))
        end)

        httpPost(SERVER_URL .. "/api/tradestatus", { twinkReady = true, name = myName })

        print("[Twink14] Ждём обнуления предметов...")
        local transferred = false
        for i = 1, 30 do
            task.wait(1)
            local _, total = snapshot()
            print("[Twink14][check] sec:", i, "total:", total)
            if total == 0 then
                transferred = true
                break
            end
        end

        if transferred then
            finishAndKick()
            return
        end

        print("[Twink14] Предметы остались | TradeGui.Enabled =", tostring(tradeGui.Enabled))

        if tradeGui.Enabled then
            print("[Twink14] TradeGui открыт — перекладываем...")
            local freshSnap, _ = snapshot()
            putItemsInTrade(tradeRem, freshSnap)
            task.spawn(function()
                pcall(function() tradeRem:InvokeServer(unpack({"AcceptTrade"})) end)
            end)
            httpPost(SERVER_URL .. "/api/tradestatus", { twinkReady = true, name = myName })
            for i = 1, 30 do
                task.wait(1)
                local _, total = snapshot()
                print("[Twink14][retry] sec:", i, "total:", total)
                if total == 0 then
                    finishAndKick()
                    return
                end
            end
        else
            print("[Twink14] TradeGui закрыт — стартуем новый трейд...")
            task.wait(3)
        end
    end

    warn("[Twink14] Исчерпаны все попытки (" .. maxAttempts .. "), трейд не завершён.")
    httpPost(SERVER_URL .. "/api/queue/done", { name = myName })

end
