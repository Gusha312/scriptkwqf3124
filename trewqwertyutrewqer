    -- ШАГ 2: Data есть, но значения могут ещё не подгрузиться — ждём ненулевых предметов
    -- Даём ещё до 60 сек на то чтобы значения стали > 0
    print("[Twink14] Ждём загрузки значений предметов...")
    local snapInit, totalBefore = {}, 0
    local valWaitMax = 60
    local valWaited  = 0
    repeat
        task.wait(3)
        valWaited += 3
        snapInit, totalBefore = snapshot()
        if valWaited % 15 == 0 then
            print("[Twink14] totalBefore =", totalBefore, "| ждём " .. valWaited .. "/" .. valWaitMax .. " сек")
        end
    until totalBefore > 0 or valWaited >= valWaitMax

    if totalBefore == 0 then
        -- После всего ожидания предметов нет — аккаунт реально пустой
        -- НЕ удаляем из статистики на случай если это баг загрузки
        warn("[Twink14] Предметов не обнаружено после " .. (dataWaited + valWaited) .. " сек ожидания.")
        warn("[Twink14] Выходим из очереди, статистику НЕ удаляем.")
        httpPost(SERVER_URL .. "/api/queue/done", { name = myName })
        return
    end
    print("[Twink14] Данные загружены! Предметов:", totalBefore, "| Время загрузки:", (dataWaited + valWaited), "сек")

    -- Строим чанки
    local chunks, allSlots = buildChunks(snapInit)
    local totalChunks = #chunks

    -- Логируем план
    print(string.format("[Twink14] Всего слотов: %d | Трейдов: %d", #allSlots, totalChunks))
    for i, chunk in ipairs(chunks) do
        local parts = {}
        for _, slot in ipairs(chunk) do
            table.insert(parts, slot.name .. " x" .. slot.amount)
        end
        print("  Трейд " .. i .. ": " .. table.concat(parts, " | "))
    end

    if totalChunks == 0 then
        print("[Twink14] Нечего передавать — убираемся из очереди.")
        httpPost(SERVER_URL .. "/api/queue/done", { name = myName })
        return
    end

    -- Проходим по чанкам
    local currentSnap = snapInit
    local maxRetries  = 3

    for i, chunk in ipairs(chunks) do
        local success   = false
        local attempts  = 0

        while not success and attempts < maxRetries do
            attempts += 1
            print("[Twink14] Чанк " .. i .. "/" .. totalChunks .. " | Попытка " .. attempts)

            local verified, snapAfter = doOneTrade(chunk, i, totalChunks, currentSnap)

            if verified then
                success = true
                currentSnap = snapAfter  -- обновляем снапшот для следующих чанков
                print("[Twink14] ✅ Чанк " .. i .. " успешно передан!")
            else
                warn("[Twink14] ❌ Чанк " .. i .. " не прошёл верификацию, попытка " .. attempts)
                -- Обновляем снапшот перед повтором — вдруг часть всё-таки прошла
                currentSnap, _ = snapshot()
                task.wait(5)
            end
        end

        if not success then
            warn("[Twink14] Чанк " .. i .. " провалился после " .. maxRetries .. " попыток! Прерываем.")
            -- НЕ удаляем из статистики — предметы могли не уйти
            failAndKick("Чанк " .. i .. " не передан после " .. maxRetries .. " попыток")
            return
        end

        -- Кулдаун между трейдами (кроме последнего)
        if i < totalChunks then
            print("[Twink14] Кулдаун " .. TRADE_COOLDOWN .. " сек перед трейдом " .. (i+1) .. "...")
            for sec = TRADE_COOLDOWN, 1, -1 do
                task.wait(1)
                if sec % 10 == 0 or sec <= 5 then
                    print("[Twink14] До следующего трейда: " .. sec .. " сек")
                end
            end
        end
    end

    -- Финальная проверка
    local _, remaining = snapshot()
    print("[Twink14] Остаток предметов после всех трейдов:", remaining)

    if remaining == 0 then
        -- Всё передано — только теперь удаляем из статистики
        finishAndKick()
    else
        -- Что-то осталось — НЕ удаляем из статистики чтобы было видно на сайте
        failAndKick("Остались предметы после всех трейдов: " .. remaining)
    end

end
