    -- Данные в трейд-мире: Players.LocalPlayer.Data
    local function getDataFolder()
        local d = player:FindFirstChild("Data")
        if d then return d end
        return nil
    end

    local function snapshot()
        local result = {}
        local total  = 0
        local folder = getDataFolder()
        if not folder then
            print("[Twink14][snapshot] Data НЕ НАЙДЕНА")
            return result, 0
        end

        local items   = folder:FindFirstChild("Items")
        local unlocks = folder:FindFirstChild("Unlocks")

        if items then
            for _, name in ipairs(tokenNames) do
                local t   = items:FindFirstChild(name)
                local val = t and tonumber(t.Value) or 0
                result[name] = val
                total += val
                if val > 0 then print("[Twink14][snapshot]", name, "=", val) end
            end
        else
            print("[Twink14][snapshot] Items не найдено")
        end

        if unlocks then
            for _, name in ipairs(creatureNames) do
                local c   = unlocks:FindFirstChild(name)
                local val = 0
                if c then
                    if type(c.Value) == "boolean" then
                        val = c.Value and 1 or 0
                    else
                        val = math.floor(tonumber(c.Value) or 0)
                    end
                end
                result[name] = val
                total += val
                if val > 0 then print("[Twink14][snapshot]", name, "=", val) end
            end
        else
            print("[Twink14][snapshot] Unlocks не найдено")
        end

        print("[Twink14][snapshot] Итого:", total)
        return result, total
    end

    -- Разбивает снапшот на чанки по 9 слотов, каждый слот макс 150 штук
    local function buildChunks(snap)
        local allSlots = {}

        local function addSlots(itemType, name, totalAmt)
            if totalAmt <= 0 then return end
            local rem = totalAmt
            while rem > 0 do
                local portion = math.min(rem, AMOUNT_PER_SLOT)
                table.insert(allSlots, { itemType = itemType, name = name, amount = portion })
                rem -= portion
            end
        end

        for _, name in ipairs(tokenNames)   do addSlots("Tokens",   name, snap[name] or 0) end
        for _, name in ipairs(creatureNames) do addSlots("Creatures", name, snap[name] or 0) end

        local chunks, current = {}, {}
        for _, slot in ipairs(allSlots) do
            if #current >= TRADE_SLOTS then
                table.insert(chunks, current)
                current = {}
            end
            table.insert(current, slot)
        end
        if #current > 0 then table.insert(chunks, current) end

        return chunks, allSlots
    end

    local function putChunkInTrade(tradeRem, chunk)
        for _, slot in ipairs(chunk) do
            local ok, err = pcall(function()
                tradeRem:InvokeServer(unpack({"AddTradeItem", {
                    Overwrite = true,
                    ItemType  = slot.itemType,
                    Name      = slot.name,
                    Amount    = slot.amount
                }}))
            end)
            print("[Twink14] Add", slot.itemType, slot.name, "x"..slot.amount,
                ok and "OK" or ("ERR:"..tostring(err)))
            task.wait(1)
        end
        print("[Twink14] Чанк положен, слотов:", #chunk)
    end

    -- Жёсткая проверка: предметы реально уменьшились
    local function verifyTradeSuccess(snapBefore, chunk)
        local expectedDelta = 0
        for _, slot in ipairs(chunk) do expectedDelta += slot.amount end
        print("[Twink14][verify] Ожидаем уменьшение на:", expectedDelta)

        for attempt = 1, 15 do
            task.wait(2)
            local snapAfter, _ = snapshot()
            local actualDelta  = 0
            local allDecreased = true

            for _, slot in ipairs(chunk) do
                local before = snapBefore[slot.name] or 0
                local after  = snapAfter[slot.name]  or 0
                local diff   = before - after
                actualDelta += diff
                if diff < slot.amount then allDecreased = false end
                print(string.format("[Twink14][verify] %s: до=%d после=%d diff=%d ожид=%d",
                    slot.name, before, after, diff, slot.amount))
            end

            print(string.format("[Twink14][verify] попытка %d/15 | delta=%d/%d",
                attempt, actualDelta, expectedDelta))

            if allDecreased and actualDelta >= expectedDelta then
                print("[Twink14][verify] ✅ Трейд подтверждён!")
                return true, snapAfter
            end
        end

        warn("[Twink14][verify] ❌ Трейд не подтверждён!")
        -- Возвращаем snapBefore чтобы не потерять данные о предметах
        return false, snapBefore
    end

