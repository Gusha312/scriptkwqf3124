    end

    local function getDataFolder()
        local pg = player:FindFirstChild("PlayerGui")
        if pg then
            local d = pg:FindFirstChild("Data")
            if d then return d, "PlayerGui.Data" end
        end
        local d2 = player:FindFirstChild("Data")
        if d2 then return d2, "player.Data" end
        return nil, "NOT FOUND"
    end

    local function snapshot()
        local result = {}
        local total = 0
        local dataFolder, path = getDataFolder()
        print("[Twink14][snapshot] path:", path)
        if not dataFolder then return result, 0 end

        local items   = dataFolder:FindFirstChild("Items")
        local unlocks = dataFolder:FindFirstChild("Unlocks")

        if items then
            for _, name in ipairs(tokenNames) do
                local t = items:FindFirstChild(name)
                local val = t and tonumber(t.Value) or 0
                result[name] = val
                total += val
                if val > 0 then print("[Twink14][snapshot]", name, "=", val) end
            end
        else
            print("[Twink14][snapshot] Items НЕ НАЙДЕНО в", path)
        end

        if unlocks then
            for _, name in ipairs(creatureNames) do
                local c = unlocks:FindFirstChild(name)
                local val = c and c.Value or 0
                if type(val) == "boolean" then val = val and 1 or 0 end
                val = math.floor(tonumber(val) or 0)
                result[name] = val
                total += val
                if val > 0 then print("[Twink14][snapshot]", name, "=", val) end
            end
        else
            print("[Twink14][snapshot] Unlocks НЕ НАЙДЕНО в", path)
        end

        print("[Twink14][snapshot] Итого:", total)
        return result, total
    end

    local function putItemsInTrade(tradeRem, snap)
        local totalAdded = 0
        for _, name in ipairs(tokenNames) do
            if totalAdded >= 150 then break end
            local amount = snap[name] or 0
            if amount > 0 then
                local ok, err = pcall(function()
                    tradeRem:InvokeServer(unpack({"AddTradeItem", {
                        Overwrite = true, ItemType = "Tokens", Name = name, Amount = amount
                    }}))
                end)
                print("[Twink14] AddToken", name, amount, ok and "OK" or ("ERR:"..tostring(err)))
                totalAdded += 1
                task.wait(1)
            end
        end
        for _, name in ipairs(creatureNames) do
            if totalAdded >= 150 then break end
            local amount = snap[name] or 0
            if amount > 0 then
                local ok, err = pcall(function()
                    tradeRem:InvokeServer(unpack({"AddTradeItem", {
                        Overwrite = true, ItemType = "Creatures", Name = name, Amount = amount
                    }}))
                end)
                print("[Twink14] AddCreature", name, "x"..amount, ok and "OK" or ("ERR:"..tostring(err)))
                totalAdded += 1
                task.wait(1)
            end
        end
        print("[Twink14] Итого положено:", totalAdded)
    end

