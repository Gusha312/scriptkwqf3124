    --[[
        buildChunks(snap):
        Разбивает все предметы на чанки с учётом двух ограничений:
        1. Максимум TRADE_SLOTS разных слотов в одном трейде
        2. Максимум AMOUNT_PER_SLOT штук одного предмета в одном слоте
           (если у предмета 152 штуки → слот 150 + слот 2 в следующем/том же трейде)

        Возвращает: массив чанков, каждый чанк = массив слотов { itemType, name, amount }
    ]]
    local function buildChunks(snap)
        -- Сначала разворачиваем все предметы в плоский список слотов
        -- с учётом лимита AMOUNT_PER_SLOT
        local allSlots = {}

        local function addSlots(itemType, name, totalAmount)
            if totalAmount <= 0 then return end
            local remaining = totalAmount
            while remaining > 0 do
                local portion = math.min(remaining, AMOUNT_PER_SLOT)
                table.insert(allSlots, { itemType = itemType, name = name, amount = portion })
                remaining -= portion
            end
        end

        for _, name in ipairs(tokenNames) do
            addSlots("Tokens", name, snap[name] or 0)
        end
        for _, name in ipairs(creatureNames) do
            addSlots("Creatures", name, snap[name] or 0)
        end

        -- Теперь разбиваем плоский список слотов на чанки по TRADE_SLOTS
        local chunks  = {}
        local current = {}
        for _, slot in ipairs(allSlots) do
            if #current >= TRADE_SLOTS then
                table.insert(chunks, current)
                current = {}
            end
            table.insert(current, slot)
        end
        if #current > 0 then
            table.insert(chunks, current)
        end

        return chunks, allSlots
    end

    -- Кладёт один чанк слотов в трейд
    local function putChunkInTrade(tradeRem, chunk)
