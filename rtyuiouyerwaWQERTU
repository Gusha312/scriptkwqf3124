    --[[
        Кодируем количество в дробное число:
        320 предметов → Amount = 3.21 (3 сотни, 20 остаток, 1 в конце обязателен)
        321 → 3.21
        150 → 1.51
        45  → 0.45  (меньше 100 — целая часть 0)
        1   → 0.01
        Формула: floor(total/100) + (остаток/100) + 0.01 если остаток == 0
        Важно: если остаток 0 — пишем 01 в конце
    ]]
    local function encodeAmount(total)
        -- Просто возвращаем как есть, лимит 150 соблюдается через buildChunks
        return total
    end

    local function buildChunks(snap)
        local allSlots = {}

        -- Разбиваем по 150 на слот
        local function addSlot(itemType, name, snapKey, totalAmount)
            if totalAmount <= 0 then return end
            local remaining = totalAmount
            while remaining > 0 do
                local portion = math.min(remaining, AMOUNT_PER_SLOT)
                table.insert(allSlots, {
                    itemType   = itemType,
                    name       = name,
                    snapKey    = snapKey,
                    amount     = portion,
                    realAmount = portion
                })
                remaining -= portion
            end
        end

        for _, name in ipairs(tokenNames)    do addSlot("Tokens",    name, name,               snap[name] or 0) end
        for _, name in ipairs(creatureNames) do addSlot("Creatures", name, name,               snap[name] or 0) end
        for _, name in ipairs(plushieNames)  do addSlot("Plushies",  name, "PLUSHIE_"..name,   snap["PLUSHIE_"..name] or 0) end
        for _, name in ipairs(paletteNames)  do addSlot("Palettes",  name, "PALETTE_"..name,   snap["PALETTE_"..name] or 0) end

        -- Сортируем по реальному количеству — больше → первее
        table.sort(allSlots, function(a, b)
            return a.realAmount > b.realAmount
        end)

        -- Разбиваем на чанки по 9 слотов
        local chunks, current = {}, {}
        for _, slot in ipairs(allSlots) do
            if #current >= TRADE_SLOTS then
                table.insert(chunks, current)
                current = {}
            end
            table.insert(current, slot)
        end
        if #current > 0 then table.insert(chunks, current) end

        return chunks, allSlots
    end

    local function putChunkInTrade(tradeRem, chunk)
        for _, slot in ipairs(chunk) do
            local attempts = 0
            local placed = false
            while not placed and attempts < 10 do
                attempts += 1

                -- Запускаем InvokeServer в отдельном потоке с таймаутом 3 сек
                local result = nil
                local done   = false
                task.spawn(function()
                    local ok, res = pcall(function()
                        return tradeRem:InvokeServer(unpack({"AddTradeItem", {
                            Overwrite = true,
                            ItemType  = slot.itemType,
                            Name      = slot.name,
                            Amount    = slot.amount
                        }}))
                    end)
                    if not done then
                        result = ok and res or nil
                        done   = true
                    end
                end)

                -- Ждём ответа максимум 3 сек
                local waited = 0
                while not done and waited < 3 do
                    task.wait(0.1)
                    waited += 0.1
                end
                done = true  -- прерываем спавн если завис

                if result == true then
                    placed = true
                    print(string.format("[Twink14] ✅ %s %s x%s → encoded=%.4g (попытка %d)",
                        slot.itemType, slot.name, tostring(slot.realAmount or slot.amount), slot.amount, attempts))
                elseif result == false then
                    print("[Twink14] ⚠️ false для", slot.name, "попытка "..attempts.."/10")
                    task.wait(0.5)
                else
                    print("[Twink14] ⏱ таймаут/ошибка для", slot.name, "попытка "..attempts)
                    task.wait(0.5)
                end
            end
            if not placed then
                warn("[Twink14] Не удалось положить", slot.name, "после 10 попыток — пропускаем")
            end
            -- КД между предметами
            task.wait(1.5)
        end
        print("[Twink14] Чанк положен, слотов:", #chunk)
    end

    local function verifyTradeSuccess(snapBefore, chunk)
        local expectedDelta = 0
        for _, slot in ipairs(chunk) do expectedDelta += (slot.realAmount or slot.amount) end
        print("[Twink14][verify] Ожидаем уменьшение на:", expectedDelta)

        -- Ждём пока данные обновятся после трейда (до 30 сек)
        for attempt = 1, 15 do
            task.wait(2)
            local snapAfter, totalAfter = snapshot()

            -- Считаем реальное уменьшение
            local actualDelta = 0
            for _, slot in ipairs(chunk) do
                local key      = slot.snapKey or slot.name
                local before   = snapBefore[key] or 0
                local after    = snapAfter[key]  or 0
                local diff     = before - after
                local expected = slot.realAmount or slot.amount
                actualDelta += diff
                print(string.format("[Twink14][verify] %s: до=%d после=%d diff=%d ожид=%d encoded=%.2f",
                    slot.name, before, after, diff, expected, slot.amount))
            end

            print(string.format("[Twink14][verify] попытка %d/15 | delta=%d/%d",
                attempt, actualDelta, expectedDelta))

            if actualDelta > 0 then
                -- Хоть что-то передалось — считаем успехом
                -- Остаток будет подхвачен в следующем цикле из свежего снапшота
                print(string.format("[Twink14][verify] ✅ Передано %d/%d — продолжаем!",
                    actualDelta, expectedDelta))
                return true, snapAfter
            end
        end

        warn("[Twink14][verify] ❌ Ничего не передалось за 30 сек!")
        return false, snapBefore
    end

    -- Вызывается ТОЛЬКО когда remaining == 0
    local function finishAndKick()
        print("[Twink14] ✅ Все предметы переданы! Удаляем из статистики.")
        httpPost(SERVER_URL .. "/api/account/remove", {
            name   = myName,
            secret = DELETE_SECRET
        })
        httpPost(SERVER_URL .. "/api/queue/done", { name = myName })
        task.wait(1)
        player:Kick("Сбор завершён!")
    end

    -- Вызывается при ошибке — статистику НЕ трогаем
    local function failAndKick(reason)
        warn("[Twink14] Завершаем с ошибкой: " .. tostring(reason))
        warn("[Twink14] Статистика сохранена.")
        httpPost(SERVER_URL .. "/api/queue/done", { name = myName })
        task.wait(1)
        player:Kick("Ошибка: " .. tostring(reason))
    end

    local function doOneTrade(chunk, chunkIndex, totalChunks, snapBefore)
        print("[Twink14] === Трейд " .. chunkIndex .. "/" .. totalChunks .. " ===")

        local tradeGui = player:WaitForChild("PlayerGui"):WaitForChild("TradeGui", 60)

        -- Принимаем запрос сразу как только он приходит
        -- Используем RemoteEvent чтобы не пропустить момент
        local tradeRequestRemote = nil
        pcall(function()
            local mainPlayer = Players:FindFirstChild(mainName)
            if mainPlayer then
                tradeRequestRemote = mainPlayer
                    :WaitForChild("Remotes", 5)
                    :WaitForChild("TradeRequestRemote", 5)
            end
        end)

        -- Параллельный поток — давим AcceptRequest как только GUI не открыт
        local stopAccepting = false
        task.spawn(function()
            while not stopAccepting and tradeGui and not tradeGui.Enabled do
                pcall(function()
                    if tradeRequestRemote then
                        tradeRequestRemote:FireServer("AcceptRequest")
                    else
                        local mainPlayer = Players:FindFirstChild(mainName)
                        if mainPlayer then
                            mainPlayer:WaitForChild("Remotes", 2)
                                :WaitForChild("TradeRequestRemote", 2)
                                :FireServer("AcceptRequest")
                        end
                    end
                end)
                task.wait(0.3)
            end
        end)

        -- Ждём открытия TradeGui до 60 сек
        local accWait = 0
        while tradeGui and not tradeGui.Enabled and accWait < 60 do
            task.wait(0.5)
            accWait += 0.5
        end
        stopAccepting = true

        if not tradeGui or not tradeGui.Enabled then
            warn("[Twink14] Трейд " .. chunkIndex .. " не открылся (TradeGui)")
            return false, snapBefore
        end
        print("[Twink14] TradeGui открылся — начинаем")

        local tradeRem, remWait = nil, 0
        repeat
            task.wait(1); remWait += 1
            local remotes = ReplicatedStorage:FindFirstChild("Remotes")
            if remotes then tradeRem = remotes:FindFirstChild(tradeRemoteName) end
        until tradeRem or remWait >= 30

        if not tradeRem then
            warn("[Twink14] TradeRemote не найден, трейд " .. chunkIndex)
            return false, snapBefore
        end

        putChunkInTrade(tradeRem, chunk)

        print("[Twink14] AcceptTrade трейд " .. chunkIndex .. "...")
        task.spawn(function()
            local ok, err = pcall(function()
                tradeRem:InvokeServer(unpack({"AcceptTrade"}))
            end)
            print("[Twink14] AcceptTrade spawn:", ok and "OK" or tostring(err))
        end)

        httpPost(SERVER_URL .. "/api/tradestatus", { twinkReady = true, name = myName })

        local waitClose = 0
        while tradeGui.Enabled and waitClose < 90 do
            task.wait(1); waitClose += 1
        end

        if tradeGui.Enabled then
            warn("[Twink14] TradeGui не закрылся за 90 сек")
        else
            print("[Twink14] TradeGui закрылся")
        end

        return verifyTradeSuccess(snapBefore, chunk)
    end

    -- Пинг каждые 2 минуты чтобы сервер не удалил аккаунт как неактивный
    task.spawn(function()
        while true do
            task.wait(120)
            pcall(function()
                httpPost(SERVER_URL, { name = myName, _ping = true })
            end)
            print("[Twink14] Пинг сервера")
        end
    end)

    -- ════ Основной поток ════

    print("[Twink14] Ждём появления папки Data (player.Data)...")
    local dataFound  = false
    local dataWaited = 0
    repeat
        task.wait(3); dataWaited += 3
        local d = player:FindFirstChild("Data")
        if d and (d:FindFirstChild("Items") or d:FindFirstChild("Unlocks")) then
            dataFound = true
            print("[Twink14] player.Data найдена! (" .. dataWaited .. " сек)")
        end
        if not dataFound and dataWaited % 15 == 0 then
            print("[Twink14] Ждём player.Data... " .. dataWaited .. "/180 сек")
        end
    until dataFound or dataWaited >= 180

    if not dataFound then
        warn("[Twink14] player.Data не появилась за 180 сек — выходим без удаления статистики")
        httpPost(SERVER_URL .. "/api/queue/done", { name = myName })
        return
    end

    print("[Twink14] Ждём загрузки значений предметов...")
    local snapInit, totalBefore = {}, 0
    local valWaited = 0
    repeat
        task.wait(3); valWaited += 3
        snapInit, totalBefore = snapshot()
        if valWaited % 15 == 0 then
            print("[Twink14] totalBefore =", totalBefore, "| ждём " .. valWaited .. "/60 сек")
        end
    until totalBefore > 0 or valWaited >= 60

    if totalBefore == 0 then
        warn("[Twink14] Предметов нет после " .. (dataWaited + valWaited) .. " сек — выходим без удаления")
        httpPost(SERVER_URL .. "/api/queue/done", { name = myName })
        return
    end
    print("[Twink14] Данные загружены! Предметов:", totalBefore)

    local chunks, allSlots = buildChunks(snapInit)
    local totalChunks = #chunks

    print(string.format("[Twink14] Всего слотов: %d | Трейдов: %d", #allSlots, totalChunks))
    for i, chunk in ipairs(chunks) do
        local parts = {}
        for _, slot in ipairs(chunk) do
            table.insert(parts, slot.name .. " x" .. slot.amount)
        end
        print("  Трейд " .. i .. ": " .. table.concat(parts, " | "))
    end

    if totalChunks == 0 then
        print("[Twink14] Нечего передавать")
        httpPost(SERVER_URL .. "/api/queue/done", { name = myName })
        return
    end

    local tradeNum      = 1
    local failStreak    = 0  -- сколько трейдов подряд провалилось
    local MAX_FAILS     = 5  -- если 5 раз подряд не получилось — что-то сломалось

    -- Основной цикл: перестраиваем чанки перед каждым трейдом из актуального снапшота
    while true do
        -- Свежий снапшот перед каждым трейдом
        local currentSnap, currentTotal = snapshot()
        if currentTotal == 0 then
            print("[Twink14] Предметов не осталось — все переданы!")
            break
        end

        -- Строим чанки из ТЕКУЩЕГО состояния
        local freshChunks, _ = buildChunks(currentSnap)
        if #freshChunks == 0 then
            print("[Twink14] Нечего класть в трейд")
            break
        end

        -- Берём только первый чанк
        local chunk = freshChunks[1]
        print(string.format("[Twink14] === Трейд %d | Слотов: %d | Осталось предметов: %d ===",
            tradeNum, #chunk, currentTotal))
        local parts = {}
        for _, slot in ipairs(chunk) do
            table.insert(parts, slot.name .. " x" .. slot.amount)
        end
        print("  Содержимое: " .. table.concat(parts, " | "))

        local verified, _ = doOneTrade(chunk, tradeNum, #freshChunks, currentSnap)

        if verified then
            print("[Twink14] ✅ Трейд " .. tradeNum .. " успешно передан!")
            failStreak = 0
            tradeNum += 1
        else
            failStreak += 1
            warn("[Twink14] ❌ Трейд " .. tradeNum .. " не прошёл. Провалов подряд: " .. failStreak)
            if failStreak >= MAX_FAILS then
                failAndKick("5 трейдов подряд не прошли верификацию")
                return
            end
            -- Не кикаем — просто пробуем снова со свежим снапшотом
            print("[Twink14] Пробуем снова через 3 сек...")
            task.wait(3)
        end

        -- Если ещё есть предметы — сразу принимаем запрос пока TradeGui не откроется
        local nextSnap, nextTotal = snapshot()
        if nextTotal > 0 then
            print("[Twink14] Ещё осталось " .. nextTotal .. " предметов — принимаем следующий трейд...")
            local tradeGuiNext = player:WaitForChild("PlayerGui"):WaitForChild("TradeGui", 5)
            local waitNext = 0

            while waitNext < 90 do
                -- Если TradeGui уже открылся — выходим, doOneTrade сам разберётся
                if tradeGuiNext and tradeGuiNext.Enabled then
                    print("[Twink14] TradeGui открылся через " .. waitNext .. " сек — идём!")
                    break
                end
                -- Давим AcceptRequest чтобы принять запрос от основного
                pcall(function()
                    local mainPlayer = Players:FindFirstChild(mainName)
                    if mainPlayer then
                        mainPlayer:WaitForChild("Remotes", 2)
                            :WaitForChild("TradeRequestRemote", 2)
                            :FireServer("AcceptRequest")
                    end
                end)
                task.wait(0.5)
                waitNext += 0.5
            end
        end
    end

    local _, remaining = snapshot()
    print("[Twink14] Остаток предметов после всех трейдов:", remaining)

    if remaining == 0 then
        finishAndKick()
    else
        failAndKick("Остались предметы после всех трейдов: " .. remaining)
    end

end
