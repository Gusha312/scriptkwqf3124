local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- [[ РАНДОМАЙЗЕР ]]
local rng = Random.new(tick() + math.random(1, 99999))

local function rwait(min, max)
    local base = rng:NextNumber(min, max)
    local jitter = rng:NextNumber(-0.05, 0.08)
    task.wait(math.max(0.05, base + jitter))
end

local function rint(min, max)
    return rng:NextInteger(min, max)
end

local function rnum(min, max)
    return rng:NextNumber(min, max)
end

local function jitterPos(x, y)
    return x + rng:NextNumber(-4, 4), y + rng:NextNumber(-4, 4)
end

-- [[ ФУНКЦИИ ПОМОЩНИКИ ]]
local function forceExpandAndClick(button)
    if not button then return end
    
    local oldSize = button.Size
    local oldPos = button.Position
    local oldZ = button.ZIndex
    local oldAnchor = button.AnchorPoint

    -- Раздувание с рандомизацией размера
    local function applyMassive()
        button.AnchorPoint = Vector2.new(0.5, 0.5)
        local randSize = rint(7000000, 9999999)
        button.Size = UDim2.new(0, randSize, 0, randSize)
        button.Position = UDim2.new(0.5, 0, 0.5, 0)
        button.ZIndex = rint(900000, 9999999)
        for _, child in pairs(button:GetChildren()) do
            if child:IsA("UIAspectRatioConstraint") then child.Enabled = false end
        end
    end

    local screenCenter = Camera.ViewportSize / 2

    -- Рандомное число кликов (2-3)
    local clickCount = rint(2, 3)
    
    for i = 1, clickCount do
        -- Рандомное время "удержания" увеличенного состояния
        local holdTime = rnum(0.3, 0.55)
        local t1 = tick()
        while tick() - t1 < holdTime do
            applyMassive()
            task.wait()
        end
        
        -- Координаты с дрожанием
        local clickX, clickY = jitterPos(screenCenter.X, screenCenter.Y)
        
        VirtualInputManager:SendMouseButtonEvent(clickX, clickY, 0, true, game, 0)
        rwait(0.04, 0.12)
        VirtualInputManager:SendMouseButtonEvent(clickX, clickY, 0, false, game, 0)
        
        if i < clickCount then
            rwait(0.3, 0.55)
        end
    end

    rwait(0.25, 0.45)
    
    button.AnchorPoint = oldAnchor
    button.Size = oldSize
    button.Position = oldPos
    button.ZIndex = oldZ
end

local function teleportTo(cframe)
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    if hrp then
        hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
        char:PivotTo(cframe)
        rwait(0.08, 0.18)
        char:PivotTo(cframe)
    end
end

-- Применяем рандомное смещение к точке телепорта
local function jitterCFrame(cf)
    local ox = rnum(-12, 12)
    local oy = rnum(-3, 3)
    local oz = rnum(-12, 12)
    return cf * CFrame.new(ox, oy, oz)
end

