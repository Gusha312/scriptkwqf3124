local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Lighting = game:GetService("Lighting")
local UserGameSettings = UserSettings():GetService("UserGameSettings")

-- Проверка PlaceId
if game.PlaceId ~= 5233782396 then
    warn("Скрипт работает только в плейсе 5233782396")
    return
end

-- Ставим графику на минимум
UserGameSettings.SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1
settings().Rendering.QualityLevel = Enum.QualityLevel.Level01

local localPlayer = Players.LocalPlayer
local remote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("AprilFoolsLeverPull")

while true do
    local coins = localPlayer.PlayerGui:WaitForChild("Data"):WaitForChild("Coins").Value

    if coins <= 1500 then
        print("Баланс " .. coins .. " — остановка.")
        break
    end

    print("Баланс " .. coins .. " > 1500 — FireServer!")
    remote:FireServer()

    local delay = math.random(2, 10)
    task.wait(delay)
end
