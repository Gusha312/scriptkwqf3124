    while true do
        hideUnwantedGuis()
        wait(1)
    end
end)

-- Функция клика по координатам
local function clickAt(posX, posY)
    VirtualInputManager:SendMouseButtonEvent(posX, posY, 0, true, game, 1)
    wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(posX, posY, 0, false, game, 1)
end

-- Клик в центр элемента (GuiObject). Работает при любом размере окна!
local function clickElement(element)
    if not element or not element:IsA("GuiObject") then return end
    local centerX = element.AbsolutePosition.X + element.AbsoluteSize.X / 2
    local centerY = element.AbsolutePosition.Y + element.AbsoluteSize.Y / 2
    clickAt(centerX, centerY)
end

-- Несколько кликов по элементу с задержкой
local function multiClickElement(element, count, delay)
    for i = 1, count do
        clickElement(element)
        if i < count then
            wait(delay or 0.3)
        end
    end
end

