local function waitUntil(cond, timeout, interval)
    local start = tick()
    interval = interval or 0.3
    while not cond() do
        if tick() - start >= timeout then return false end
        task.wait(interval)
    end
    return true
end

local function teleportTo(cframe)
    hrp.CFrame = cframe + Vector3.new(0, 3, 0)
end

-- ======= ДРАКОН =======
local function getDragonId()
    local ok1, d1 = pcall(function() return character:FindFirstChild("Dragons") end)
    if ok1 and d1 then local c = d1:GetChildren(); if #c > 0 then return c[1].Name end end
    local ok2, d2 = pcall(function() return Workspace.Characters[player.Name].Dragons end)
    if ok2 and d2 then local c = d2:GetChildren(); if #c > 0 then return c[1].Name end end
    local ok3, d3 = pcall(function() return player.Data.Dragons end)
    if ok3 and d3 then local c = d3:GetChildren(); if #c > 0 then return c[1].Name end end
    return "1"
end

local cachedPlaySound = nil

local function getPlaySound()
    if cachedPlaySound and cachedPlaySound.Parent then return cachedPlaySound end
    local ok1, ps1 = pcall(function()
        local dragons = character:FindFirstChild("Dragons")
        if not dragons then error() end
        local id = getDragonId()
        local dragon = dragons:FindFirstChild(id) or dragons:GetChildren()[1]
        if not dragon then error() end
        return dragon:WaitForChild("Remotes"):WaitForChild("PlaySoundRemote")
    end)
    if ok1 and ps1 then cachedPlaySound = ps1; return ps1 end
    local ok2, ps2 = pcall(function()
        local dragons = character:FindFirstChild("Dragons")
        if not dragons then error() end
        for _, dragon in ipairs(dragons:GetChildren()) do
            local r = dragon:FindFirstChild("Remotes")
            if r then
                local ps = r:FindFirstChild("PlaySoundRemote")
                if ps then return ps end
            end
        end
        error()
    end)
    if ok2 and ps2 then cachedPlaySound = ps2; return ps2 end
    return nil
end

local function fireAttack(attackType, target)
    local ps = getPlaySound()
    if ps then
        local ok = pcall(function() ps:FireServer("Breath", attackType, target) end)
        if ok then return end
    end
    cachedPlaySound = nil
    pcall(function()
        local dragons = character:FindFirstChild("Dragons")
        if not dragons then return end
        for _, dragon in ipairs(dragons:GetChildren()) do
            local r = dragon:FindFirstChild("Remotes")
            if r then
                local psr = r:FindFirstChild("PlaySoundRemote")
                if psr then
                    psr:FireServer("Breath", attackType, target)
                    cachedPlaySound = psr
                    break
                end
            end
        end
    end)
end

local function attackBoss(id)
    if not bossExists(id) then return end
    local root = Workspace.ActiveBossModels[id].HumanoidRootPart
    local ps = getPlaySound()
    if ps then
        pcall(function() ps:FireServer("Breath", "Bosses", root) end)
    else
        cachedPlaySound = nil
        pcall(function()
            local dragons = character:FindFirstChild("Dragons")
            if not dragons then return end
            for _, dragon in ipairs(dragons:GetChildren()) do
                local r = dragon:FindFirstChild("Remotes")
                if r then
                    local psr = r:FindFirstChild("PlaySoundRemote")
                    if psr then
                        psr:FireServer("Breath", "Bosses", root)
                        cachedPlaySound = psr
                        return
                    end
                end
            end
        end)
    end
end

local function checkAndReviveDragon()
    local dragonId = getDragonId()
    if not dragonId then return end
    local ok, health = pcall(function() return player.Data.Dragons[dragonId].Health.Value end)
    if ok and health ~= nil and health <= 0 then
        print("[BOT] Дракон мёртв — воскрешаем!")
        pcall(function() Remotes:WaitForChild("HealDragonRemote"):InvokeServer(dragonId, "RevivalHeart") end)
        task.wait(1)
        pcall(function() Remotes:WaitForChild("EquipDragonRemote"):InvokeServer(dragonId) end)
        task.wait(1)
        cachedPlaySound = nil
    end
end

-- ======= МОБЫ =======
local MobFolder

local function getMobsInRadius(position, radius)
    local mobs = {}
    if not MobFolder then return mobs end
    for _, mob in ipairs(MobFolder:GetChildren()) do
        local mobRoot = mob:FindFirstChild(mob.Name)
        if mobRoot then
            local alive = true
            local hok, health = pcall(function() return mobRoot:FindFirstChild("Health").Value end)
            if hok and health ~= nil and health <= 0 then alive = false end
            if alive and (position - mobRoot.Position).Magnitude <= radius then
                table.insert(mobs, mobRoot)
            end
        end
    end
    return mobs
end

local function killMobsAtSpawn(spawnCFrame, radius, slot)
    local function isMobAlive(mobRoot)
        local ok, health = pcall(function() return mobRoot:FindFirstChild("Health").Value end)
        return ok and health and health > 0
    end

    local startTime = tick()
    while tick() - startTime < 30 do
        local mobs = getMobsInRadius(spawnCFrame.Position, radius)
        local ok, sp = pcall(function() return slot.SpawnPart end)
        if ok and sp then
            for _, m in ipairs(getMobsInRadius(sp.Position, radius)) do
                local found = false
                for _, e in ipairs(mobs) do if e == m then found = true; break end end
                if not found then table.insert(mobs, m) end
            end
        end
        if #mobs == 0 then
            print("[BOT] Мобы убиты!")
            break
        end
        for _, mobRoot in ipairs(mobs) do
            if isMobAlive(mobRoot) then
                local mobPos = mobRoot.Position
                hrp.CFrame = CFrame.new(mobPos + Vector3.new(0, 5, 0))
                task.wait(0.2)
                local attackCount = 0
                while isMobAlive(mobRoot) and attackCount < 5 do
                    fireAttack("Mobs", mobRoot)
                    task.wait(0.15)
                    attackCount = attackCount + 1
                end
            end
        end
        task.wait(0.5)
    end
    teleportTo(spawnCFrame)
end

