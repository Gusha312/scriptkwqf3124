local function getMobsInRadius(position, radius)
    local mobs = {}
    if not MobFolder then return mobs end
    for _, mob in ipairs(MobFolder:GetChildren()) do
        local mobRoot = mob:FindFirstChild(mob.Name)
        if mobRoot then
            local alive = true
            local healthOk, health = pcall(function()
                return mobRoot:FindFirstChild("Health").Value
            end)
            if healthOk and health ~= nil and health <= 0 then alive = false end
            if alive then
                local dist = (position - mobRoot.Position).Magnitude
                if dist <= radius then table.insert(mobs, mobRoot) end
            end
        end
    end
    return mobs
end

local function killMobsAtSpawn(spawnCFrame, radius)
    teleportTo(spawnCFrame)
    task.wait(0.3)
    local startTime = tick()
    while tick() - startTime < 30 do
        -- Ищем мобов у спавна мобов
        local mobs = getMobsInRadius(spawnCFrame.Position, radius)
        -- Добавляем мобов у SpawnPart босса
        local ok, sp = pcall(function() return slot.SpawnPart end)
        if ok and sp then
            for _, m in ipairs(getMobsInRadius(sp.Position, radius)) do
                local found = false
                for _, existing in ipairs(mobs) do
                    if existing == m then found = true; break end
                end
                if not found then table.insert(mobs, m) end
            end
        end
        if #mobs == 0 then
            print("[BOT] Мобы убиты!")
            break
        end
        for _, mobRoot in ipairs(mobs) do
            attackMob(mobRoot)
            task.wait(0.1)
        end
    end
end

