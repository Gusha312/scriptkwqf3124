local function runBossCycle()
    local fightId = nil

    -- Ждём пока старый FightId пропадёт
    local oldId = getFightId()
    if oldId then
        print("[BOT] Ждём пока старый FightId пропадёт: " .. oldId)
        waitUntil(function()
            return getFightId() == nil
        end, 30, 0.5)
        task.wait(1)
    end

    -- Проверяем здоровье дракона перед циклом
    checkAndReviveDragon()

    -- Создаём очередь с повторами пока не появится FightId
    fightId = nil
    local queueAttempts = 0
    while not fightId do
        queueAttempts = queueAttempts + 1
        print("[BOT] Создаём очередь (попытка " .. queueAttempts .. ")...")
        Remotes.CreateBossQueueRemote:InvokeServer("Everyone")
        Remotes.StartBossQueueRemote:InvokeServer()

        waitUntil(function()
            fightId = getFightId()
            return fightId ~= nil
        end, 15, 0.5)

        if not fightId then
            print("[BOT] FightId не появился, ждём 5 сек...")
            task.wait(5)
        end
    end
    print("[BOT] FightId: " .. fightId)

    -- Телепортируемся и ждём появления слота рядом с нами
    local slot = nil
    local tpAttempts = 0
    repeat
        tpAttempts = tpAttempts + 1
        print("[BOT] Телепорт к боссу (попытка " .. tpAttempts .. ")...")
        Remotes.GetTeleportRemote:InvokeServer("ToBossInstance", {FightId = fightId, Spawn = true})
        task.wait(4)
        -- Ищем слот у которого SpawnPart рядом с нами
        for i = 1, 6 do
            local ok, s = pcall(function() return Workspace.Interactions.Boss.InstancePositions[tostring(i)] end)
            if ok and s then
                local ok2, sp = pcall(function() return s.SpawnPart end)
                if ok2 and sp then
                    local dist = (hrp.Position - sp.Position).Magnitude
                    if dist < 150 then
                        slot = s
                        print("[BOT] Наш слот: " .. i .. " dist=" .. math.floor(dist))
                        break
                    end
                end
            end
        end
    until slot ~= nil or tpAttempts >= 10
    task.wait(1)

    if not slot then
        reportError("Слот не найден рядом после 10 попыток телепорта")
        task.wait(2)
        return false
    end

    local function teleportToSpawnPart()
        local ok, sp = pcall(function() return slot.SpawnPart end)
        if not ok or not sp then return false end
        local spawnPos = sp.Position + Vector3.new(0, 5, 0)
        for i = 1, 15 do
            hrp.CFrame = CFrame.new(spawnPos)
            task.wait(0.3)
            local dist = (hrp.Position - sp.Position).Magnitude
            print("[BOT] ТП к SpawnPart dist=" .. math.floor(dist) .. " попытка=" .. i)
            if dist < 25 then
                print("[BOT] Успешно на SpawnPart!")
                return true
            end
        end
        print("[BOT] SpawnPart недостижима, продолжаем всё равно")
        return true -- продолжаем даже если не добрались
    end
    teleportToSpawnPart()

    local bossFound = waitUntil(function() return bossExists(fightId) end, 30, 0.5)
    if not bossFound then
        print("[BOT] Босс не появился, повтор...")
        task.wait(2)
        return false
    end
    print("[BOT] Босс появился!")

    -- Stage 1 — 3 потока атаки + 1 поток удержания позиции
    local stage1Active = true
    for t = 1, 3 do
        task.spawn(function()
            while stage1Active do attackBoss(fightId) task.wait(0.05) end
        end)
    end
    -- Поток удержания позиции на SpawnPart
    task.spawn(function()
        while stage1Active do
            local ok, sp = pcall(function() return slot.SpawnPart end)
            if ok and sp then
                local dist = (hrp.Position - sp.Position).Magnitude
                if dist > 100 then
                    hrp.CFrame = CFrame.new(sp.Position + Vector3.new(0, 5, 0))
                end
            end
            task.wait(1)
        end
    end)
    local stage1Start = tick()
    while getStage(fightId) ~= 2 do
        task.wait(0.5)
        if tick() - stage1Start > 10 then
            stage1Start = tick()
            print("[BOT] Stage 1 текущий: " .. tostring(getStage(fightId)) .. " FightId: " .. tostring(fightId))
        end
    end
    stage1Active = false
    print("[BOT] Stage 2!")

    -- Stage 2 — мобы
    local spawnOrder = {3, 2, 1, 4}
    while getStage(fightId) ~= 3 do
        for _, spawnNum in ipairs(spawnOrder) do
            if getStage(fightId) == 3 then break end
            local sok, spawn = pcall(function() return slot.MobSpawns[tostring(spawnNum)] end)
            if sok and spawn then killMobsAtSpawn(spawn.CFrame, 100) end
        end
    end
    print("[BOT] Stage 3!")

    -- Телепортируемся на платформу босса для Stage 3
    print("[BOT] ТП к SpawnPart для Stage 3...")
    teleportToSpawnPart()

    -- Stage 3 — 3 потока атаки + 1 поток удержания позиции
    local stage3Active = true
    for t = 1, 3 do
        task.spawn(function()
            while stage3Active do attackBoss(fightId) task.wait(0.05) end
        end)
    end
    task.spawn(function()
        while stage3Active do
            local ok, sp = pcall(function() return slot.SpawnPart end)
            if ok and sp then
                local dist = (hrp.Position - sp.Position).Magnitude
                if dist > 100 then
                    hrp.CFrame = CFrame.new(sp.Position + Vector3.new(0, 5, 0))
                end
            end
            task.wait(1)
        end
    end)
    while not isDead(fightId) do task.wait(0.1) end
    stage3Active = false
    print("[BOT] Босс убит!")

    -- Ждём GUI наград (макс 30 сек)
    collectingLoot = true
    local LootFrame = nil
    print("[BOT] Ждём GUI наград...")
    waitUntil(function()
        local ok, g = pcall(function() return player.PlayerGui.BossGui end)
        if ok and g then
            local ok2, lf = pcall(function() return g.LootFrame end)
            if ok2 and lf and lf.Visible then LootFrame = lf; return true end
        end
        return false
    end, 30, 0.5)

    if LootFrame then
        task.wait(1)

        -- Находим лучший сундук (приоритет Potion, иначе 3)
        local chestsFrame = LootFrame:FindFirstChild("ChestsFrame")
        local bestChest = nil
        if chestsFrame then
            -- Ищем сундук с Potion
            for _, chestNum in ipairs({"1", "2", "3"}) do
                local chest = chestsFrame:FindFirstChild(chestNum)
                if chest then
                    local ok, nameText = pcall(function()
                        return chest.ItemLabel.NameLabel.Text
                    end)
                    if ok and nameText and nameText:find("Potion") then
                        bestChest = chest
                        print("[BOT] Нашли Potion в сундуке " .. chestNum)
                        break
                    end
                end
            end
            -- Если Potion не нашли — берём 3й
            if not bestChest then
                bestChest = chestsFrame:FindFirstChild("3")
                print("[BOT] Potion не найден, берём сундук 3")
            end
        end

        -- Кликаем на выбранный сундук
        if bestChest then
            local ok1, btn1 = pcall(function() return bestChest:WaitForChild("ClaimButton", 3):WaitForChild("UpperLabel", 3) end)
            if ok1 and btn1 then
                clickButton(btn1)
                waitUntil(function()
                    local ok, v = pcall(function() return not btn1.Parent end)
                    return ok and v
                end, 3, 0.2)
            end
        end

        -- Кнопка ClaimButton основная
        local ok2, btn2 = pcall(function() return LootFrame:WaitForChild("ClaimButton", 3):WaitForChild("UpperLabel", 3) end)
        if ok2 and btn2 then
            clickButton(btn2)
            waitUntil(function()
                local ok, v = pcall(function() return not btn2.Parent end)
                return ok and v
            end, 3, 0.2)
        end

        -- Кнопка LeaveButton — спамим пока LootFrame не скроется
        local ok3, btn3 = pcall(function() return LootFrame:WaitForChild("LeaveButton", 3):WaitForChild("UpperLabel", 3) end)
        if ok3 and btn3 then
            local leaveStart = tick()
            while LootFrame.Visible and tick() - leaveStart < 15 do
                clickButton(btn3)
                task.wait(0.3)
            end
            if not LootFrame.Visible then
                print("[BOT] LeaveButton нажата успешно!")
            else
                print("[BOT] LeaveButton не сработала за 15 сек!")
            end
        end

        print("[BOT] Награды собраны!")
    else
        print("[BOT] GUI наград не появился!")
    end
    collectingLoot = false

    -- Ждём пока старый FightId пропадёт
    local oldId = fightId
    waitUntil(function()
        local cur = getFightId()
        return cur == nil or cur ~= oldId
    end, 20, 0.5)
    print("[BOT] FightId пропал, готовы к новому циклу!")
    task.wait(2)
    return true
end

-- ======= STORMBOUND ПЛЕЙС =======
local function runStormboundPlace()
    print("[STORMBOUND] Запуск в Stormbound плейсе...")

    -- Если сразу 0 яиц — сразу возвращаемся
    if getStormboundCount() <= 0 then
        print("[STORMBOUND] Яиц нет сразу — возвращаемся на фарм!")
        local attempts0 = 0
        repeat
            attempts0 = attempts0 + 1
            Remotes:WaitForChild("WorldTeleportRemote"):InvokeServer(3475419198, {MoveBackToAdventure = true})
            task.wait(5)
        until (attempts0 >= 5)
        return
    end

    -- Телепортируемся к своему плоту
    print("[STORMBOUND] Телепортируемся к плоту...")
    local posBefore = hrp.Position
    local tpAttempts = 0
    repeat
        tpAttempts = tpAttempts + 1
        Remotes:WaitForChild("GetTeleportRemote"):InvokeServer("Plot", PLOT_NAME)
        task.wait(3)
    until (hrp.Position - posBefore).Magnitude > 10 or tpAttempts >= 5
    print("[STORMBOUND] На плоту!")
    task.wait(1)

    -- Собираем из инкубаторов
    claimIncubators()
    task.wait(0.5)

    -- Управляем драконами
    manageDragons()
    task.wait(0.5)

    -- Если есть яйца — ставим
    if getStormboundCount() > 0 then
        placeEggs("StormboundEgg")
        task.wait(0.5)
    end

    -- Возвращаемся
    print("[STORMBOUND] Готово, возвращаемся на фарм!")
    local posBefore2 = hrp.Position
    local attempts2 = 0
    repeat
        attempts2 = attempts2 + 1
        Remotes:WaitForChild("WorldTeleportRemote"):InvokeServer(3475419198, {MoveBackToAdventure = true})
        task.wait(5)
    until (hrp.Position - posBefore2).Magnitude > 50 or attempts2 >= 5
end

-- ======= ОСНОВНОЙ ПЛЕЙС =======
local function runMainPlace()
    print("[MAIN] Запуск в основном плейсе...")
    MobFolder = Workspace:WaitForChild("MobFolder")

    -- Главный поэтапный цикл
    local cycles = 0
    while true do
        -- Проверяем Stormbound
        if getStormboundCount() >= STORMBOUND_LIMIT then
            print("[STORMBOUND] " .. getStormboundCount() .. " яиц — телепортируемся!")
            local posBefore = hrp.Position
            local attempts = 0
            repeat
                attempts = attempts + 1
                Remotes:WaitForChild("WorldTeleportRemote"):InvokeServer(3475397644, {SpawnAtPlot = true})
                task.wait(5)
            until (hrp.Position - posBefore).Magnitude > 50 or attempts >= 5
            task.wait(5)
            continue
        end

        if isMissionDone() then
            print("[QUEST] Миссия выполнена! Фармим боссов 5 мин...")
            local missionWait = tick()
            while tick() - missionWait < 300 do
                local success = runBossCycle()
                if success then
                    cycles = cycles + 1
                    print("[BOT] Цикл #" .. cycles .. " (во время кд миссии)")
                end
                task.wait(1)
            end
            continue
        end

        print("[QUEST] Q1:" .. getAmount(1) .. "/2 Q2:" .. getAmount(2) .. "/5 Q3:" .. getAmount(3) .. "/30")

        -- Шаг 1: Квест 1 — убиваем боссов
        if not isQuestDone(1) then
            print("[QUEST1] Нужно убить боссов (" .. getAmount(1) .. "/2), запускаем boss farm...")
            local success = runBossCycle()
            if success then
                cycles = cycles + 1
                print("[BOT] Цикл #" .. cycles .. " завершён!")
            end
            task.wait(1)
            continue -- возвращаемся в начало чтобы проверить статус
        end

        -- Шаг 2: Квест 2 — яйца
        if not isQuestDone(2) then
            print("[QUEST2] Пожертвование яиц (" .. getAmount(2) .. "/5)...")
            if getGrasslandCount() < 5 then
                farmGrasslandEggs(5)
            end
            Remotes:WaitForChild("OfferItemArchiesConservationProjectsMissionRemote"):InvokeServer("2", "Repeatable", "1", "2")
            task.wait(0.5)
            waitUntil(function() return isQuestDone(2) end, 10, 0.5)
            print("[QUEST2] Выполнен!")
            continue
        end

        -- Шаг 3: Квест 3 — еда
        if not isQuestDone(3) then
            print("[QUEST3] Жертвуем еду (" .. getAmount(3) .. "/30)...")
            Remotes:WaitForChild("OfferItemArchiesConservationProjectsMissionRemote"):InvokeServer("2", "Repeatable", "1", "3")
            task.wait(0.5)
            waitUntil(function() return isQuestDone(3) end, 10, 0.5)
            print("[QUEST3] Выполнен!")
            continue
        end

        -- Все квесты выполнены — фармим боссов пока ждём
        print("[QUEST] Все квесты выполнены! Фармим боссов 5 мин...")
        local allDoneWait = tick()
        while tick() - allDoneWait < 300 do
            local success = runBossCycle()
            if success then
                cycles = cycles + 1
                print("[BOT] Цикл #" .. cycles .. " (во время кд квестов)")
            end
            task.wait(1)
        end
    end
end

-- ======= ОПРЕДЕЛЯЕМ ПЛЕЙС И ЗАПУСКАЕМ =======
if PLACE_ID == PLACE_STORMBOUND then
    runStormboundPlace()
elseif PLACE_ID == PLACE_MAIN then
    runMainPlace()
else
    print("[BOT] Неизвестный плейс: " .. PLACE_ID .. " — запускаем основной режим")
    runMainPlace()
end
