-- ======= BOSS FARM =======
local function getFightId()
    local ok, instances = pcall(function()
        return Workspace.Interactions.Boss.BossInstances
    end)
    if not ok then return nil end
    for _, inst in ipairs(instances:GetChildren()) do
        if inst.Name:sub(-#player.Name) == player.Name then
            return inst.Name
        end
    end
    return nil
end

local function getInstanceSlot()
    for i = 1, 6 do
        local ok, slot = pcall(function()
            return Workspace.Interactions.Boss.InstancePositions[tostring(i)]
        end)
        if ok and slot then
            local spawnOk, _ = pcall(function() return slot.SpawnPart end)
            if spawnOk then return slot end
        end
    end
    return nil
end

local function getStage(id)
    local ok, val = pcall(function()
        return Workspace.Interactions.Boss.BossInstances[id].Stage.Value
    end)
    return ok and val or 0
end

local function isDead(id)
    local ok, val = pcall(function()
        return Workspace.Interactions.Boss.BossInstances[id].Dead.Value
    end)
    return ok and val or false
end

local function bossExists(id)
    local ok, _ = pcall(function()
        return Workspace.ActiveBossModels[id].HumanoidRootPart
    end)
    return ok
end

local function attackBoss(id)
    local ok, root = pcall(function()
        return Workspace.ActiveBossModels[id].HumanoidRootPart
    end)
    if ok and root then
        getPlaySound():FireServer("Breath", "Bosses", root)
    end
end

local function attackMob(mobRoot)
    getPlaySound():FireServer("Breath", "Mobs", mobRoot)
end

local function getMobsInRadius(position, radius)
    local mobs = {}
    if not MobFolder then return mobs end
    for _, mob in ipairs(MobFolder:GetChildren()) do
        local mobRoot = mob:FindFirstChild(mob.Name)
        if mobRoot then
            local alive = true
            local healthOk, health = pcall(function()
                return mobRoot:FindFirstChild("Health").Value
            end)
            if healthOk and health ~= nil and health <= 0 then alive = false end
            if alive then
                local dist = (position - mobRoot.Position).Magnitude
                if dist <= radius then table.insert(mobs, mobRoot) end
            end
        end
    end
    return mobs
end

local function killMobsAtSpawn(spawnCFrame, radius)
    teleportTo(spawnCFrame)
    task.wait(0.3)
    while true do
        local mobs = getMobsInRadius(spawnCFrame.Position, radius)
        if #mobs == 0 then break end
        for _, mobRoot in ipairs(mobs) do
            attackMob(mobRoot)
            task.wait(0.1)
        end
    end
end

local function clickButton(btn)
    if not btn then return end
    btn.Size = UDim2.new(1000, 1000, 1000, 1000)
    task.wait(0.2)
    local pos = btn.AbsolutePosition
    local size = btn.AbsoluteSize
    VIM:SendMouseButtonEvent(pos.X + size.X/2, pos.Y + size.Y/2, 0, true, game, 1)
    task.wait(0.1)
    VIM:SendMouseButtonEvent(pos.X + size.X/2, pos.Y + size.Y/2, 0, false, game, 1)
    task.wait(0.2)
    btn.Size = UDim2.new(1, 1, 1, 1)
    task.wait(0.2)
end

local function runBossCycle()
    local fightId = nil

    print("[BOT] Создаём очередь...")
    Remotes.CreateBossQueueRemote:InvokeServer("Everyone")
    Remotes.StartBossQueueRemote:InvokeServer()

    local found = waitUntil(function()
        fightId = getFightId()
        return fightId ~= nil
    end, 30, 0.5)

    if not found or not fightId then
        print("[BOT] FightId не найден, повтор...")
        task.wait(2)
        return false
    end
    print("[BOT] FightId: " .. fightId)

    local posBefore = hrp.Position
    local tpAttempts = 0
    repeat
        tpAttempts = tpAttempts + 1
        Remotes.GetTeleportRemote:InvokeServer("ToBossInstance", {FightId = fightId, Spawn = true})
        task.wait(5)
    until (hrp.Position - posBefore).Magnitude > 50 or tpAttempts >= 5
    if (hrp.Position - posBefore).Magnitude <= 50 then
        print("[BOT] Телепорт не удался, повтор цикла...")
        return false
    end
    task.wait(1)

    local slot = nil
    waitUntil(function()
        slot = getInstanceSlot()
        return slot ~= nil
    end, 20, 0.5)

    if not slot then
        print("[BOT] Слот не найден, повтор...")
        task.wait(2)
        return false
    end

    local spawnOk, spawnPart = pcall(function() return slot.SpawnPart end)
    if spawnOk and spawnPart then
        local spawnPos = spawnPart.Position
        local attempts = 0
        repeat
            teleportTo(spawnPart.CFrame)
            task.wait(0.5)
            attempts = attempts + 1
            local dist = (hrp.Position - spawnPos).Magnitude
            print("[BOT] ТП к SpawnPart, dist=" .. math.floor(dist) .. " попытка=" .. attempts)
        until (hrp.Position - spawnPos).Magnitude < 20 or attempts >= 10

        if (hrp.Position - spawnPos).Magnitude >= 20 then
            print("[BOT] Не удалось тепнуться к SpawnPart, повтор...")
            task.wait(2)
            return false
        end
        print("[BOT] Успешно на SpawnPart!")
    end

    local bossFound = waitUntil(function() return bossExists(fightId) end, 30, 0.5)
    if not bossFound then
        print("[BOT] Босс не появился, повтор...")
        task.wait(2)
        return false
    end
    print("[BOT] Босс появился!")

    -- Stage 1 — 3 потока
    local stage1Active = true
    for t = 1, 3 do
        task.spawn(function()
            while stage1Active do attackBoss(fightId) task.wait(0.05) end
        end)
    end
    while getStage(fightId) ~= 2 do task.wait(0.1) end
    stage1Active = false
    print("[BOT] Stage 2!")

    -- Stage 2 — мобы
    local spawnOrder = {3, 2, 1, 4}
    while getStage(fightId) ~= 3 do
        for _, spawnNum in ipairs(spawnOrder) do
            if getStage(fightId) == 3 then break end
            local sok, spawn = pcall(function() return slot.MobSpawns[tostring(spawnNum)] end)
            if sok and spawn then killMobsAtSpawn(spawn.CFrame, 150) end
        end
    end
    print("[BOT] Stage 3!")

    -- Телепортируемся на платформу босса (как в Stage 1)
    local spawnOk3, spawnPart3 = pcall(function() return slot.SpawnPart end)
    if spawnOk3 and spawnPart3 then
        teleportTo(spawnPart3.CFrame)
        print("[BOT] Телепорт к SpawnPart для Stage 3")
    end

    -- Stage 3 — 3 потока
    local stage3Active = true
    for t = 1, 3 do
        task.spawn(function()
            while stage3Active do attackBoss(fightId) task.wait(0.05) end
        end)
    end
    while not isDead(fightId) do task.wait(0.1) end
    stage3Active = false
    print("[BOT] Босс убит!")

    -- Ждём GUI наград (макс 30 сек)
    local LootFrame = nil
    print("[BOT] Ждём GUI наград...")
    waitUntil(function()
        local ok, g = pcall(function() return player.PlayerGui.BossGui end)
        if ok and g then
            local ok2, lf = pcall(function() return g.LootFrame end)
            if ok2 and lf and lf.Visible then LootFrame = lf; return true end
        end
        return false
    end, 30, 0.5)

    if LootFrame then
        task.wait(1)

        -- Кнопка 1
        local ok1, btn1 = pcall(function() return LootFrame:WaitForChild("ChestsFrame", 3):WaitForChild("3", 3):WaitForChild("ClaimButton", 3):WaitForChild("UpperLabel", 3) end)
        if ok1 and btn1 then
            clickButton(btn1)
            -- Проверяем что кнопка исчезла или стала неактивной
            waitUntil(function()
                local ok, v = pcall(function() return not btn1.Parent end)
                return ok and v
            end, 3, 0.2)
        end

        -- Кнопка 2
        local ok2, btn2 = pcall(function() return LootFrame:WaitForChild("ClaimButton", 3):WaitForChild("UpperLabel", 3) end)
        if ok2 and btn2 then
            clickButton(btn2)
            waitUntil(function()
                local ok, v = pcall(function() return not btn2.Parent end)
                return ok and v
            end, 3, 0.2)
        end

        -- Кнопка LeaveButton — спамим пока LootFrame не скроется
        local ok3, btn3 = pcall(function() return LootFrame:WaitForChild("LeaveButton", 3):WaitForChild("UpperLabel", 3) end)
        if ok3 and btn3 then
            local leaveStart = tick()
            while LootFrame.Visible and tick() - leaveStart < 15 do
                clickButton(btn3)
                task.wait(0.3)
            end
            if not LootFrame.Visible then
                print("[BOT] LeaveButton нажата успешно!")
            else
                print("[BOT] LeaveButton не сработала за 15 сек!")
            end
        end

        print("[BOT] Награды собраны!")
    else
        print("[BOT] GUI наград не появился!")
    end

    -- Ждём пока FightId пропадёт
    local oldId = fightId
    waitUntil(function()
        local cur = getFightId()
        return cur == nil or cur ~= oldId
    end, 30, 0.5)
    task.wait(2)
    return true
end

-- ======= STORMBOUND ПЛЕЙС =======
local function runStormboundPlace()
    print("[STORMBOUND] Запуск в Stormbound плейсе...")

    while true do
        -- Собираем из инкубаторов
        claimIncubators()
        task.wait(0.5)

        -- Управляем драконами
        manageDragons()
        task.wait(0.5)

        -- Если есть яйца — ставим
        if getStormboundCount() > 0 then
            placeEggs("StormboundEgg")
        end

        -- Если яиц нет — возвращаемся
        if getStormboundCount() <= 0 then
            print("[STORMBOUND] Яиц нет, возвращаемся!")
            local posBefore2 = hrp.Position
            local attempts2 = 0
            repeat
                attempts2 = attempts2 + 1
                Remotes:WaitForChild("WorldTeleportRemote"):InvokeServer(3475419198, {MoveBackToAdventure = true})
                task.wait(5)
            until (hrp.Position - posBefore2).Magnitude > 50 or attempts2 >= 5
            task.wait(5)
        end

        task.wait(30)
    end
end

-- ======= ОСНОВНОЙ ПЛЕЙС =======
local function runMainPlace()
    print("[MAIN] Запуск в основном плейсе...")
    MobFolder = Workspace:WaitForChild("MobFolder")

    -- Quest loop в отдельном потоке
    task.spawn(function()
        while true do
            if not isMissionDone() then
                print("[QUEST] Q1:" .. getAmount(1) .. "/2 Q2:" .. getAmount(2) .. "/5 Q3:" .. getAmount(3) .. "/30")

                if not isQuestDone(1) then
                    print("[QUEST1] Ждём убийства боссов (" .. getAmount(1) .. "/2)...")
                    waitUntil(function() return isQuestDone(1) end, 1200, 2)
                end

                if not isQuestDone(2) then doQuest2() end
                if not isQuestDone(3) then doQuest3() end

                if isQuestDone(1) and isQuestDone(2) and isQuestDone(3) then
                    print("[QUEST] Все выполнены! Ждём 5 мин...")
                    task.wait(300)
                end
            else
                print("[QUEST] Миссия выполнена! Ждём 5 мин...")
                task.wait(300)
            end
            task.wait(5)
        end
    end)

    -- Инкубаторы в отдельном потоке
    task.spawn(function()
        while true do
            claimIncubators()
            task.wait(0.5)
            manageDragons()
            task.wait(0.5)
            placeEggs("DesertEgg")
            task.wait(30)
        end
    end)

    -- Проверка Stormbound в отдельном потоке
    task.spawn(function()
        while true do
            if getStormboundCount() >= STORMBOUND_LIMIT then
                print("[STORMBOUND] " .. getStormboundCount() .. " яиц — телепортируемся!")
                local posBefore = hrp.Position
                local attempts = 0
                repeat
                    attempts = attempts + 1
                    Remotes:WaitForChild("WorldTeleportRemote"):InvokeServer(3475397644, {SpawnAtPlot = true})
                    task.wait(5)
                until (hrp.Position - posBefore).Magnitude > 50 or attempts >= 5
                task.wait(5)
            end
            task.wait(10)
        end
    end)

    -- Boss loop
    local cycles = 0
    while true do
        local success = runBossCycle()
        if success then
            cycles = cycles + 1
            print("[BOT] Цикл #" .. cycles .. " завершён!")
        end
        task.wait(1)
    end
end

-- ======= ОПРЕДЕЛЯЕМ ПЛЕЙС И ЗАПУСКАЕМ =======
if PLACE_ID == PLACE_STORMBOUND then
    runStormboundPlace()
elseif PLACE_ID == PLACE_MAIN then
    runMainPlace()
else
    print("[BOT] Неизвестный плейс: " .. PLACE_ID .. " — запускаем основной режим")
    runMainPlace()
end
