local function findActiveNest()
    local ok, activeNode = pcall(function()
        return Workspace.Interactions.Nodes.Eggs.ActiveNodes.Grassland
    end)
    if not ok or not activeNode then return nil, nil end
    local ok2, nestTop = pcall(function() return activeNode.NestTop end)
    if not ok2 or not nestTop then return nil, nil end
    local targetPos = nestTop.CFrame.Position
    local eggsFolder = Workspace.Interactions.Nodes.Eggs
    for i = 1, 20 do
        local ok3, nest = pcall(function() return eggsFolder[tostring(i)].Nest end)
        if ok3 and nest then
            local ok4, nestVal = pcall(function() return nest.Value end)
            if ok4 and nestVal then
                local nums = {}
                for n in tostring(nestVal):gmatch("[-]?%d+%.?%d*") do
                    table.insert(nums, tonumber(n))
                end
                if #nums >= 3 then
                    local nestPos = Vector3.new(nums[1], nums[2], nums[3])
                    if (nestPos - targetPos).Magnitude <= 10 then
                        return i, nestTop.CFrame
                    end
                end
            end
        end
    end
    return nil, nestTop.CFrame
end

local function farmGrasslandEggs(needed)
    print("[QUEST] Фармим Grassland яйца (нужно " .. needed .. ")...")
    local lastUse = 0
    while getGrasslandCount() < needed do
        local now = tick()
        if now - lastUse < 15 then task.wait(15 - (now - lastUse)) end
        local nestId, nestCFrame = findActiveNest()
        if nestCFrame then
            hrp.CFrame = nestCFrame
            task.wait(0.2)
            hrp.CFrame = nestCFrame
        end
        local startId = nestId or 1
        for i = startId, startId + 19 do
            Remotes:WaitForChild("CollectEggRemote"):InvokeServer(tostring(i))
        end
        lastUse = tick()
        print("[QUEST] Яиц: " .. getGrasslandCount() .. "/" .. needed)
    end
end

local function doQuest2()
    if isQuestDone(2) then return end
    print("[QUEST2] Пожертвование яиц (" .. getAmount(2) .. "/5)...")
    if getGrasslandCount() < 5 then farmGrasslandEggs(5) end
    Remotes:WaitForChild("OfferItemArchiesConservationProjectsMissionRemote"):InvokeServer("2", "Repeatable", "1", "2")
    task.wait(0.5)
    waitUntil(function() return isQuestDone(2) end, 10, 0.5)
    print("[QUEST2] Выполнен!")
end

local function doQuest3()
