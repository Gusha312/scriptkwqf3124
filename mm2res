end

local function runBossCycle()
    checkAndReviveDragon()

    local fightId = nil
    local queueAttempts = 0
    while not fightId do
        queueAttempts = queueAttempts + 1
        print("[BOT] Очередь (попытка " .. queueAttempts .. ")...")
        Remotes.CreateBossQueueRemote:InvokeServer("Everyone")
        Remotes.StartBossQueueRemote:InvokeServer()
        waitUntil(function() fightId = getFightId(); return fightId ~= nil end, 15, 0.5)
        if not fightId then task.wait(5) end
    end
    print("[BOT] FightId: " .. fightId)

    local slot = nil
    local tpAttempts = 0
    repeat
        tpAttempts = tpAttempts + 1
        print("[BOT] ТП к боссу (попытка " .. tpAttempts .. ")...")
        Remotes.GetTeleportRemote:InvokeServer("ToBossInstance", {FightId = fightId, Spawn = true})
        local waited = 0
        while waited < 8 do
            slot = getInstanceSlot()
            if slot then break end
            task.wait(0.5); waited = waited + 0.5
        end
    until slot ~= nil or tpAttempts >= 10
    task.wait(1)

    if not slot then
        reportError("Слот не найден после 10 попыток")
        task.wait(2)
        return false
    end
    print("[BOT] Слот: " .. slot.Name)

    local function tpToSpawn()
        local ok, sp = pcall(function() return slot.SpawnPart end)
        if not ok or not sp then return end
        local pos = sp.Position + Vector3.new(0, 5, 0)
        for i = 1, 15 do
            hrp.CFrame = CFrame.new(pos)
            task.wait(0.3)
            if (hrp.Position - sp.Position).Magnitude < 25 then
                print("[BOT] На SpawnPart!")
                return
            end
        end
    end
    tpToSpawn()

    if not waitUntil(function() return bossExists(fightId) end, 30, 0.5) then
        reportError("Босс не появился за 30 сек")
        task.wait(2)
        return false
    end
    print("[BOT] Босс появился!")

    -- Stage 1
    local s1Active = true
    for i = 1, 3 do
        task.spawn(function()
            while s1Active do
                attackBoss(fightId)
                task.wait(0.08)
            end
        end)
    end
    task.spawn(function()
        while s1Active do
            local ok, sp = pcall(function() return slot.SpawnPart end)
            if ok and sp and (hrp.Position - sp.Position).Magnitude > 100 then
                hrp.CFrame = CFrame.new(sp.Position + Vector3.new(0, 5, 0))
            end
            task.wait(1)
        end
    end)
    local s1t = tick()
    while getStage(fightId) ~= 2 do
        task.wait(0.5)
        if tick() - s1t > 10 then s1t = tick(); print("[BOT] Stage 1: " .. getStage(fightId)) end
    end
    s1Active = false
    print("[BOT] Stage 2!")

    -- Stage 2 — мобы
    for _, n in ipairs({3,2,1,4}) do
        if getStage(fightId) == 3 then break end
        local ok, spawn = pcall(function() return slot.MobSpawns[tostring(n)] end)
        if ok and spawn then killMobsAtSpawn(spawn.CFrame, 100, slot) end
    end
    while getStage(fightId) ~= 3 do
        for _, n in ipairs({3,2,1,4}) do
            if getStage(fightId) == 3 then break end
            local ok, spawn = pcall(function() return slot.MobSpawns[tostring(n)] end)
            if ok and spawn then killMobsAtSpawn(spawn.CFrame, 100, slot) end
        end
    end
    print("[BOT] Stage 3!")

    -- Stage 3
    tpToSpawn()
    local s3Active = true
    for i = 1, 3 do
        task.spawn(function()
            while s3Active do
                attackBoss(fightId)
                task.wait(0.08)
            end
        end)
    end
    task.spawn(function()
        while s3Active do
            local ok, sp = pcall(function() return slot.SpawnPart end)
            if ok and sp and (hrp.Position - sp.Position).Magnitude > 100 then
                hrp.CFrame = CFrame.new(sp.Position + Vector3.new(0, 5, 0))
            end
            task.wait(1)
        end
    end)
    while not isDead(fightId) do task.wait(0.1) end
    s3Active = false
    print("[BOT] Босс убит!")

    -- =============================================
    -- СБОР НАГРАД (ОПТИМИЗИРОВАН, БЕЗ СПАМА)
    -- =============================================
    collectingLoot = true
    local LootFrame = nil
    print("[BOT] Ждём GUI наград...")
    waitUntil(function()
        local ok, g = pcall(function() return player.PlayerGui.BossGui end)
        if ok and g then
            local ok2, lf = pcall(function() return g.LootFrame end)
            if ok2 and lf and lf.Visible then LootFrame = lf; return true end
        end
        return false
    end, 30, 0.5)

    if LootFrame then
        task.wait(1)

        local chestsFrame = LootFrame:FindFirstChild("ChestsFrame")
        local bestChest = nil
        if chestsFrame then
            for _, chestNum in ipairs({"1","2","3"}) do
                local chest = chestsFrame:FindFirstChild(chestNum)
                if chest then
                    local ok, nameText = pcall(function() return chest.ItemLabel.NameLabel.Text end)
                    if ok and nameText and nameText:find("Potion") then
                        bestChest = chest
                        break
                    end
                end
            end
            bestChest = bestChest or chestsFrame:FindFirstChild("3")
        end

        if bestChest then
            local btn = bestChest:FindFirstChild("ClaimButton")
            if btn then
                local upper = btn:FindFirstChild("UpperLabel")
                if upper then clickButton(upper) end
            end
            task.wait(1.5)
        end

        local claimBtn = LootFrame:FindFirstChild("ClaimButton")
        if claimBtn then
            local upper = claimBtn:FindFirstChild("UpperLabel")
            if upper then
                clickButton(upper)
                task.wait(2)
            end
        end

        local leaveBtn = LootFrame:FindFirstChild("LeaveButton")
        if leaveBtn then
            local upper = leaveBtn:FindFirstChild("UpperLabel")
            if upper then
                for _ = 1, 5 do
                    if not LootFrame.Visible then break end
                    clickButton(upper)
                    task.wait(1.5)
                end
            end
        end
        print("[BOT] Награды собраны!")
    else
        print("[BOT] GUI наград не появился!")
    end
    collectingLoot = false

    local oldId = fightId
    print("[BOT] Ждём FightId пропадёт...")
    local ws = tick()
    while tick()-ws < 60 do
        local cur = getFightId()
        if cur == nil or cur ~= oldId then break end
        task.wait(1)
    end
    waitUntil(function()
        local ok, inst = pcall(function() return Workspace.Interactions.Boss.BossInstances[oldId] end)
        return not ok or not inst or not inst.Parent
    end, 30, 0.5)
    print("[BOT] Готовы к новому циклу!")
    task.wait(3)
    return true
end

