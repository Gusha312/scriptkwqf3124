local cachedPlaySound = nil

local function getPlaySound()
    -- Проверяем кэш
    if cachedPlaySound and cachedPlaySound.Parent then
        return cachedPlaySound
    end
    -- Пробуем найти через character.Dragons
    local dragonId = getDragonId()
    -- Вариант 1: через character
    local ok1, ps1 = pcall(function()
        local dragons = character:FindFirstChild("Dragons")
        if not dragons then error("no Dragons") end
        local dragon = dragons:FindFirstChild(dragonId) or dragons:GetChildren()[1]
        if not dragon then error("no dragon") end
        return dragon:WaitForChild("Remotes"):WaitForChild("PlaySoundRemote")
    end)
    if ok1 and ps1 then
        cachedPlaySound = ps1
        return ps1
    end
    -- Вариант 2: перебираем всех драконов в character
    local ok2, ps2 = pcall(function()
        local dragons = character:FindFirstChild("Dragons")
        if not dragons then error("no Dragons") end
        for _, dragon in ipairs(dragons:GetChildren()) do
            local r = dragon:FindFirstChild("Remotes")
            if r then
                local ps = r:FindFirstChild("PlaySoundRemote")
                if ps then return ps end
            end
        end
        error("not found")
    end)
    if ok2 and ps2 then
        cachedPlaySound = ps2
        return ps2
    end
    return nil
end

