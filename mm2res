    local origSize, origPos, origAnchor, origZIndex = btn.Size, btn.Position, btn.AnchorPoint, btn.ZIndex
    btn.Size = UDim2.new(100, 0, 100, 0)
    btn.Position = UDim2.new(0.5, 0, 0.5, 0)
    btn.AnchorPoint = Vector2.new(0.5, 0.5)
    btn.ZIndex = 99999
    task.wait(0.5)
    local screen = Workspace.CurrentCamera.ViewportSize
    VIM:SendMouseButtonEvent(math.floor(screen.X/2), math.floor(screen.Y/2), 0, true, game, 1)
    task.wait(0.15)
    VIM:SendMouseButtonEvent(math.floor(screen.X/2), math.floor(screen.Y/2), 0, false, game, 1)
    task.wait(0.3)
    btn.Size = origSize; btn.Position = origPos; btn.AnchorPoint = origAnchor; btn.ZIndex = origZIndex
    task.wait(0.2)
end

