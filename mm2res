-- ======= ХЕЛПЕРЫ =======
local function waitUntil(cond, timeout, interval)
    local start = tick()
    interval = interval or 0.3
    while not cond() do
        if tick() - start >= timeout then return false end
        task.wait(interval)
    end
    return true
end

local function teleportTo(cframe)
    hrp.CFrame = cframe + Vector3.new(0, 3, 0)
end

local function getDragonId()
    local ok, dragons = pcall(function()
        return Workspace.Characters[player.Name].Dragons
    end)
    if ok and dragons then
        local children = dragons:GetChildren()
        if #children > 0 then
            return children[1].Name
        end
    end
    return "1" -- fallback
end

local function getPlaySound()
    local dragonId = getDragonId()
    return character:WaitForChild("Dragons"):WaitForChild(dragonId):WaitForChild("Remotes"):WaitForChild("PlaySoundRemote")
end

-- ======= ИНКУБАТОРЫ =======
local function getIncubators()
    local incubators = {}
    local ok, buildings = pcall(function()
        return Workspace.Interactions.Plots.Plots[PLOT_NAME].Base.Buildings
    end)
    if not ok then return incubators end
    for _, b in ipairs(buildings:GetChildren()) do
        if b.Name == "Incubator" then
            table.insert(incubators, b)
        end
    end
    return incubators
end

local function getStormboundCount()
    local ok, val = pcall(function() return player.Data.Eggs.StormboundEgg.Value end)
    return ok and val or 0
end

local function getGrasslandCount()
    local ok, val = pcall(function() return player.Data.Eggs.GrasslandEgg.Value end)
    return ok and val or 0
end

local function placeEggs(eggName)
    print("[BOT] Раскладываем " .. eggName .. " в инкубаторы...")
    local incubators = getIncubators()
    local placed = 0
    for _, inc in ipairs(incubators) do
        local count = eggName == "StormboundEgg" and getStormboundCount() or getGrasslandCount()
        if count <= 0 then break end
        if not inc:FindFirstChild("Egg") then
            local ok, remote = pcall(function() return inc:WaitForChild("IncubateRemote", 2) end)
            if ok and remote then
                remote:InvokeServer(eggName)
                placed = placed + 1
                print("[BOT] Поставили " .. eggName .. " (" .. placed .. ")")
                task.wait(0.3)
            end
        end
    end
    print("[BOT] Поставлено: " .. placed)
end

local function claimIncubators()
    print("[BOT] Собираем из инкубаторов...")
    local incubators = getIncubators()
    for _, inc in ipairs(incubators) do
        if inc:FindFirstChild("Egg") then
            local ok, remote = pcall(function() return inc:WaitForChild("ClaimRemote", 2) end)
            if ok and remote then
                remote:InvokeServer()
                print("[BOT] Собрали из инкубатора")
                task.wait(0.5)
            end
        end
    end
end

-- ======= ДРАКОНЫ =======
local KEEP_DRAGONS = {"Veidreki", "Seikarin", "Atarix"}

local function keepDragon(name)
    for _, k in ipairs(KEEP_DRAGONS) do
        if name == k then return true end
    end
    return false
end

local function manageDragons()
    local ok, dragons = pcall(function() return player.Data.Dragons end)
    if not ok then return end
    for _, dragon in ipairs(dragons:GetChildren()) do
        local id = dragon.Name
        local ok2, dragonName = pcall(function() return dragon.Value end)
        if not ok2 then continue end

        local ok3, cosmetic = pcall(function() return dragon.Genetics.Cosmetic.Value end)
        if ok3 and cosmetic == "[Error:Cosmetic]" then
            print("[BOT] Дракон " .. id .. " Cosmetic — пропускаем")
            continue
        end

        if not keepDragon(dragonName) then
            print("[BOT] Удаляем дракона " .. id .. " (" .. tostring(dragonName) .. ")")
            pcall(function()
                Remotes:WaitForChild("DeleteDragonRemote"):InvokeServer({tostring(id)})
            end)
            task.wait(0.3)
        end
    end
end

